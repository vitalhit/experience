<div class="row">
	<div class="col-xs-12 col-md-6">
		<h2 class="tac mt0">Цитаты ждут генерации</h2>
	</div>
	<div class="col-xs-12 col-md-6">
		<a href="/quote/create" class="btn btn-success pull-right ml10">Добавить цитату</a>
		<a href="/quote/generate" class="btn btn-primary pull-right">Генерировать</a>
	</div>
</div>
<h2 class="tac">Цитаты ждут генерации</h2>
<table class="table">
	{% for row in q %}
		<tr>
			<td>{{row.id}}</td>
			<td>{{row.autor}}</td>
			<td>{{row.text}}</td>
            <td><a href="/quote/update?id={{ row.id }}"><span class="glyphicon glyphicon-pencil"></span></a></td>
            <td><a href="/quote/delete?id={{ row.id }}" title="Delete" aria-label="Delete" data-confirm="Уверены, что хотите удалить?" data-method="post"><span class="glyphicon glyphicon-trash"></span></a></td>
		</tr>
	{% endfor %}
</table>



<h2 class="tac">Готовые цитаты</h2>
<table class="table">
	{% for row in q_d %}
		<tr>
			<td>{{row.id}}</td>
			<td>{{row.autor}}</td>
			<td>{{row.text}}</td>
            <td><a href="/quote/update?id={{ row.id }}"><span class="glyphicon glyphicon-pencil"></span></a></td>
            <td><a href="/quote/delete?id={{ row.id }}" title="Delete" aria-label="Delete" data-confirm="Уверены, что хотите удалить?" data-method="post"><span class="glyphicon glyphicon-trash"></span></a></td>
		</tr>
	{% endfor %}
</table>


<div class="clear"></div>

{% if photos  %}
	{% for photo in photos %}
		<div class="col-xs-12 col-md-2 mb10">
			<img src="/web/{{ photo }}" class="img-responsive">
			{{ photo }}
		</div>
	{% endfor %}
{% endif %}