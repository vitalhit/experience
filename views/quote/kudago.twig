
<link href="/css/quote.css" rel="stylesheet">
<script src="/js/quote.js" type="text/javascript"></script>


<p class="ph1 text-center">Генератор Цитат</p>
<p class="text-center">Все, что не генерится - все к лучшему</p>



<div class="container mt50">

	<form id="form1" action="/quote/donekudago" method="POST">

		<div class="col-xs-12 col-md-4">
			<h3>Введите текст цитаты</h3>
			<textarea name="text" id="text" class="input" placeholder="Введите текст цитаты"></textarea> 
		</div>

		<div class="col-xs-12 col-md-4">
			<h3>Выберите фон</h3>
			<label class="col-xs-12 col-sm-3">
				<input type="radio" class="fon" name="fon" value="nonameceramics-01" required="" checked>
				<img class="inimg" src="/images/nonameceramics-01.jpg">
			</label>
			<label class="col-xs-12 col-sm-3">
				<input type="radio" class="fon" name="fon" value="kudago" required="" checked>
				<img class="inimg" src="/images/kudago.jpg">
			</label>
			<label class="col-xs-12 col-sm-3">
				<input type="radio" class="fon" name="fon" value="v3" required="">
				<img class="inimg" src="/images/v3.jpg">
			</label>
			<label class="col-xs-12 col-sm-3">
				<input type="radio" class="fon" name="fon" value="kudago1" required="">
				<img class="inimg" src="/images/kudago1.jpg">
			</label>
			<label class="col-xs-12 col-sm-3">
				<input type="radio" class="fon" name="fon" value="kudago2" required="">
				<img class="inimg" src="/images/kudago2.jpg">
			</label>
			<label class="col-xs-12 col-sm-2">
				<input type="radio" class="fon" name="fon" value="fon_l_2_m" required="" checked="">
				<img class="inimg" src="/images/fon_l_2_m.jpg">
			</label>
			<label class="col-xs-12 col-sm-2">
				<input type="radio" class="fon" name="fon" value="fon_l_2_m-white-wm" required="" checked="">
				<img class="inimg" src="/images/fon_l_2_m-white-wm.jpg">
			</label>
			<label class="col-xs-12 col-sm-2">
				<input type="radio" class="fon" name="fon" value="fon_l_2_m_wood_wm" required="" checked="">
				<img class="inimg" src="/images/fon_l_2_m_wood_wm.jpg">
			</label>
			<label class="col-xs-12 col-sm-2">
				<input type="radio" class="fon" name="fon" value="fon_l_2_m-wall-wm" required="" checked="">
				<img class="inimg" src="/images/fon_l_2_m-wall-wm.jpg">
			</label>
			
			<label class="col-xs-12 col-sm-2">
				<input type="radio" class="fon" name="fon" value="harplivemusic_6270-2-1kx1k-b70" required="" checked="">
				<img class="inimg" src="/images/harplivemusic_6270-2-1kx1k-b70.jpg">
			</label>
		</div>


		<div class="col-xs-12 col-md-4">
			<h3>Настройте шрифт</h3>
			<div class="col-xs-12 col-md-4">
				<h4>Размер</h4>
				<label><input type="radio" class="size" name="size" value="12" required> 12px</label>
				<label><input type="radio" class="size" name="size" value="16" required> 16px</label>
				<label><input type="radio" class="size" name="size" value="20" required> 20px</label>
				<label><input type="radio" class="size" name="size" value="24" required> 24px</label>
				<label><input type="radio" class="size" name="size" value="28" required checked> 28px</label>
			</div>
			<!-- <div class="col-xs-12 col-md-4">
				<h4>Центр</h4>
				<label><input type="radio" class="centr" name="centr" value="left" required> влево</label>
				<label><input type="radio" class="centr" name="centr" value="center" required checked> центр</label>
				<label><input type="radio" class="centr" name="centr" value="right" required> вправо</label>
			</div> -->
			<div class="col-xs-12 col-md-4">
				<h4>Цвет</h4>
				<label><input type="radio" class="color" name="colr" value="#fff"> Белый</label>
				<label><input type="radio" class="color" name="colr" value="#000" checked> Черный</label>
				<input class="input" type="text" id="color" name="color" placeholder=" свой: ffffff" required>
			</div>	
		</div>


		<div class="clear mt50"></div>
		<h3>Получите картинку</h3>

		<div class="col-xs-12 col-md-4 col-md-offset-2">
			<h4>Предпросмотр</h4>
			<div id="preview">
				<img src="" id="img_preview" width=300>
				<div id="text_preview"></div>
			</div>
		</div>
		<div class="clear mt50"></div>

		<div class="col-xs-12 col-md-4 col-md-offset-4">
			<input type="submit" name="" class="btn btn-primary" value="Получить картинку"> 
		</div>
	</form>




	{% if photos  %}
		{% for photo in photos %}
			<div class="col-xs-12 col-md-2 mb10">
				<img src="{{ photo }}" class="img-responsive">
			</div>
		{% endfor %}
	{% endif %}


</div> 





<div class="footer">
	<h4>Генератор цитат</h4>
	<div class="soc">
		<a class="ss" href=""><img src="/images/vk.png"></a>
		<a class="ss" href=""><img src="/images/yt.png"></a>
		<a class="ss" href=""><img width="26px" src="/images/telegram.png"></a>
		<!-- //запрещенные
		<a class="ss" href=""><img src="/images/insta.png"></a>
		<a class="ss" href=""><img src="/images/fb.png"></a>-->
		<a class="ss" href=""><img src="/images/web.png"></a>
	</div>
</div>


<div class="overlay"></div>
