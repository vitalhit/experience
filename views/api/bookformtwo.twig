<div class="endreg">
	<div class="ttl">Закончить регистрацию?</div>
	<p>После этого вернуть введенные вами данные будет невозможно.</p>
	<a class="widget_button1 igo_popup_goon">Нет, продолжить</a>
	<a class="widget_button2 igo_popup_close">Завершить</a>
</div>

<div class="igo_form">
	<div class="igo_close"></div>
	<!-- bookformtwo.twig -->
	<form id="igo_book_form" method="POST" action="">
		<input type="hidden" name="from_url" class="from_url" value="">
		<input type="hidden" name="id" class="id" value="">
		<input type="hidden" name="company_id" class="company_id" value="{{ company_id }}">
		<input type="hidden" name="biblioevent_id" type="hidden" class="biblioevent_id" value="{{ biblioevent.id }}">
		<input type="hidden" name="list_id" class="list_id" value="{{biblioevent.list_id }}">
		<input type="hidden" name="utm_source" value="">
		<input type="hidden" name="utm_medium" value="">
		<input type="hidden" name="utm_campaign" value="">
		<input type="hidden" name="utm_content" value="">
		<input type="hidden" name="utm_term" value="">

		<div style="width: 50%; float: left; padding-right: 10px;">
			{% if template == 1 %}
			<div class="form-group">
				<input   class="form-control info_wish required" aria-required="true" type="text" placeholder="Желаемые даты участия*" name="info_wish">
			</div>
			{% endif %}
			<div class="form-group">
				<input class="form-control second_name required" type="text" name="second_name" placeholder="Фамилия*" value="">
			</div>
			<div class="form-group">
				<input class="form-control name required" type="text" name="name" placeholder="Имя*" value="">
			</div>
			{% if biblioevent.id==158 %} <!-- для маркета 4 сезона -->
			<div class="form-group">
				<input class="form-control thirdname required" type="text" name="thirdname" placeholder="Отчество*" value="">
			</div>
			<div class="form-group">
				<input   class="form-control info_wish required" aria-required="true" type="text" placeholder="Желаемые даты участия*" name="info_wish">
			</div>
			<div class="form-group">
				<input class="form-control brand required" type="text" name="brand" placeholder="Название вашего бренда*" value="">
			</div>
			<div class="form-group">
				<input class="form-control info_cat required" type="text" name="info_cat" placeholder="Категория вашего товара*" value="">
			</div>

			{% endif %}


			{% if template == 1 %}
			<div class="form-group">
				<input class="form-control second_name required" type="text" name="thirdname" placeholder="Отчество*" value="">
			</div>
			{% endif %}

			<div class="form-group">
				<input class="form-control igo_mail required" type="text" name="mail" placeholder="Email*" value="">
			</div>
			<div class="form-group">
				<input class="form-control phone required" type="text" name="phone" placeholder="Телефон*" value="">
			</div> 
			
			{% if template == 1 %}
			<div class="form-group">
				<input class="form-control brand required" type="text" name="brand" placeholder="Название бренда*" value="">
			</div>
			<div class="form-group">
				<input class="form-control link_site " type="text" name="link_site" placeholder="сайт с https://.." value="">
			</div>
			<div class="form-group">
				<input class="form-control link_vk " type="text" name="link_vk" placeholder="ВК с https://.." value="">
			</div>
			<div class="form-group">
				<input class="form-control link_fb " type="text" name="link_fb" placeholder="facebook с https://.." value="">
			</div>
			<div class="form-group">
				<input class="form-control link_insta " type="text" name="link_insta" placeholder="instagram(https://..)" value="">
			</div>
			{% endif %}
			{% if biblioevent.template_id == 3 %}
			<textarea style="height: 74px;" required class="form-control message" type="text" placeholder="Сообщение*" name="message"></textarea>
			{% endif %}

		</div>

		<div style="width: 50%; float: left; padding-left: 10px;">
			
			{% if template == 1 %}
			<div class="form-group">
				<input class="form-control info_wish required" type="text" name="info_wish" placeholder="Категория вашего товара" value="">
			</div>
			<textarea style="height: 132px;" class="form-control message" type="text" placeholder="Имя-фамилия вашего соседа(если делите стол с партнером, от вас и от него необходимы заявки по данной форме)" name="message"></textarea>
			
			<input   class="form-control message2 required" aria-required="true" type="text" placeholder="ссылка на папку с фото продукции*" name="message2">
			{% elseif biblioevent.template_id == 3 %}
			
			<textarea style="height: 80px;" required class="form-control info_wish" type="text" placeholder="Каковы ваши ожидания от обучения?" name="info_wish"></textarea>
			<textarea style="height: 80px;" required class="form-control info_goal" type="text" placeholder=" К какой цели вы хотите прийти в конце обучения?" name="info_goal"></textarea>
			<textarea style="height: 80px;" required class="form-control info_job" type="text" placeholder="Род деятельности , чем вы занимаетесь?" name="info_job"></textarea>
			{% elseif biblioevent.id==158 %}
			
			{% if biblioevent.id==158 %}
			<textarea style="height: 132px;" required class="form-control message" type="text" placeholder="АКТИВНАЯ ссылка на группу вконтакте, сайт, другой веб-ресурс (т.е. не просто название аккаунта @foursiz, а именно активная ссылка) " name="message"></textarea>
			

			{% endif %}
			{% else %}
			<textarea style="height: 232px;" required class="form-control message" type="text" placeholder="Сообщение*" name="message"></textarea>
			{% endif %}



		</div>
		<button type="submit" id="submit" class="btn btn-primary center-block book_submit">Отправить заявку</button>
		<div class="form-group col-xs-12">
			<label class="reg_accept">
				<input type="checkbox" name="subscribe" checked="checked">
				<!-- 211117 здесь редактировать --><span>Я хочу получать информацию об интересных событиях</span>
			</label>
		</div>
		<div class="form-group col-xs-12">
			<label class="reg_accept">
				<input type="checkbox" name="accepted_terms" onchange="document.getElementById('submit').disabled = !this.checked" checked="">
				<span>Я согласен с условиями <a target="_blank" href="https://igoevent.com/pdf/iGoEvent_useragreement.pdf">Пользовательского соглашения</a> и <a href="https://igoevent.com/site/oferta/{{ biblioevent.id }}" target="_blank"> Договором оказания услуг </a> 
				</span>
			</label>
		</div>
		
	</form>