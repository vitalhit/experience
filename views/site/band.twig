{% if band.landing.seodesc %}
	{{ this.registerMetaTag({name: 'keywords', content: band.landing.seodesc}) | raw }}
{% else %}
	{{ this.registerMetaTag({name: 'keywords', content: band.name}) | raw }}
{% endif %}

{% if band.landing.seokey %}
	{{ this.registerMetaTag({name: 'description', content: band.landing.seokey}) | raw }}
{% else %}
	{{ this.registerMetaTag({name: 'description', content: band.name}) | raw }}
{% endif %}


{% if band.landing.ogtitle %}
	{{ this.registerMetaTag({name: 'og:title', content: band.landing.ogtitle}) | raw }}
{% else %}
	{{ this.registerMetaTag({name: 'og:title', content: band.name}) | raw }}
{% endif %}

{% if band.landing.ogdescription %}
	{{ this.registerMetaTag({name: 'og:description', content: band.landing.ogdescription}) | raw }}
{% else %}
	{{ this.registerMetaTag({name: 'og:description', content: band.name}) | raw }}
{% endif %}

{% if band.landing.ogimage %}
	{% set ogimage = ['/uploads/users/', band.landing.ogimage ]|join %}
{% elseif band.landing.image %}
	{% set ogimage = ['/uploads/users/', band.landing.image ]|join %}
{% else %}
	{% set ogimage = ['/uploads/users/', band.image ]|join %}
{% endif %}
{{ this.registerMetaTag({name: 'og:image', content: ogimage}) | raw }}

{% set ogurl = ['/band/', band.id]|join %}
{{ this.registerMetaTag({name: 'og:url', content: ogurl}) | raw }}

{{ this.registerMetaTag({name: 'og:type', content: 'website'}) | raw }}




<div class="container-full title-page" style="background: url('/uploads/users/{{ band.image }}') 50% {% if band.imagept %}{{band.imagept}}{% else %}50{% endif %}% no-repeat transparent;">
	<div class="container">
		<div class="breadcrumbs">
			<a class="home-link" href="/"><img src="/images/logo-mini-white.svg"></a>
		</div>
 		<div class="statics">
			{#<span class="years">6+</span>
			<span class="views">921</span>#}
			<span class=""><a href="https://crm.igoevent.com/crm/band/view?id={{ band.id }}" class="u-profile">Edit</a></span>
		</div> 


		<div class="col-xs-12 col-sm-10 col-sm-offset-1 col-md-8 col-md-offset-2 title-block">
			<h1>{% if band.landing.title %}{{ band.landing.title }}{% else %}{{ band.name }}{% endif %}</h1>
			<p>{% if band.anons %}{{ band.anons }}{% else %}{{ band.description }}{% endif %}</p>
		</div>
	</div>
</div>

<div class="container">
	<div class="section-block">
		<div class="event-row">
			{% if band.activeevents or events %}
				<h1>Ближайшие события</h1>


				{% for item in events%}
					<div class="event">
							<a class="img-event" href="/{{ item.biblioevents.cities.alias }}/event/{% if item.biblioevents.alias %}{{ item.biblioevents.alias }}{% else %}{{ item.biblioevents.id }}{% endif %}">
								{# <span class="comments">12</span><span class="like">410</span> #}
								<img src="/uploads/users/{{ item.biblioevents.img.imgrazdel }}">
							</a>
							{# <span class="type-event">категория</span> #}
							<a class="title-event" href="/{{ item.biblioevents.cities.alias }}/event/{% if item.biblioevents.alias %}{{ item.biblioevents.alias }}{% else %}{{ item.biblioevents.id }}{% endif %}">
								<h3>{{ item.biblioevents.name }} {# <small>6+</small> #}</h3>
							</a>
							<span class="point"><span style="color:red;">{{ item.biblioevents.cities.name }}</span>{% if item.biblioevents.show_date > 0 %}: {{ item.date|date('d.m.Y ') }} в {{ item.date|date('H:i') }}{%else%}{% endif %}</span> 
							{% if item.link_vk %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ item.link_vk }}"> <img src="/images/vk.png" alt=""></a>{% endif %}
							{% if item.link_fb %}<a style="float: right; margin-right: 20px;"class="soc" href="{{ item.link_fb }}"> <img src="/images/fb.png" alt=""></a>{% endif %}
							{# <span class="views">9214</span> #}
						</div>
				{% endfor %}

				{% for row in band.activeevents %}
					{% if row.biblioevents.image and row.hide_in_band != '1' %}
						<div class="event">
							<a class="img-event" href="/{{ row.biblioevents.cities.alias }}/event/{% if row.biblioevents.alias %}{{ row.biblioevents.alias }}{% else %}{{ row.biblioevents.id }}{% endif %}">
								{# <span class="comments">12</span><span class="like">410</span> #}
								<img src="/uploads/users/{{ row.biblioevents.img.imgrazdel }}">
							</a>
							{# <span class="type-event">категория</span> #}
							<a class="title-event" href="/{{ row.biblioevents.cities.alias }}/event/{% if row.biblioevents.alias %}{{ row.biblioevents.alias }}{% else %}{{ row.biblioevents.id }}{% endif %}">
								<h3>{{ row.biblioevents.name }} {# <small>6+</small> #}</h3>
							</a>
							<span class="point"><span style="color:red;">{{ row.biblioevents.cities.name }}</span>{% if row.biblioevents.show_date > 0 %}: {{ row.date|date('d.m.Y ') }} в {{ row.date|date('H:i') }}{%else%}{% endif %}</span> 
							{% if row.link_vk %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ row.link_vk }}"> <img src="/images/vk.png" alt=""></a>{% endif %}
							{% if row.link_fb %}<a style="float: right; margin-right: 20px;"class="soc" href="{{ row.link_fb }}"> <img src="/images/fb.png" alt=""></a>{% endif %}
							{# <span class="views">9214</span> #}
						</div>
					{% endif %}
				{% endfor %}
			{% else %}
				{% if band.mark_future == -1 %}

				{% else%}
				<h3>{% if band.name_genitive %} У {{ band.name_genitive }} нет запланированных событий.{% elseif  band.name_genitive is empty %} Нет запланированных событий)  {% endif %}  </h3>
				{% endif %}
			{% endif %}


			<div class="clear"></div>
			
			<div class='content'>
				{{ band.info_top|raw }}
			</div>

			<span class="clearfix"></span>
			{% if biblioevents %}
				<h1>Вы можете оставить заявку на события</h1>

				{% for row in biblioevents %}
					{% if row.biblioevents.image %}
						<div class="event">
							<a class="img-event" href="/{{ row.biblioevents.cities.alias }}/event/{% if row.biblioevents.alias %}{{ row.biblioevents.alias }}{% else %}{{ row.biblioevents.id }}{% endif %}">
								{# <span class="comments">12</span><span class="like">410</span> #}
								<img src="/uploads/users/{{ row.biblioevents.img.imgrazdel }}">
							</a>
							
							<a class="title-event" href="/{{ row.biblioevents.cities.alias }}/event/{% if row.biblioevents.alias %}{{ row.biblioevents.alias }}{% else %}{{ row.biblioevents.id }}{% endif %}">
								<h3>{{ row.biblioevents.name }} {# <small>6+</small> #}</h3>
							</a>
							<span class="point"><span style="color:red;">{{ row.biblioevents.cities.name }}</span></span> 
							{% if row.link_vk %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ row.link_vk }}"> <img src="/images/vk.png" alt=""></a>{% endif %}
							{% if row.link_fb %}<a style="float: right; margin-right: 20px;"class="soc" href="{{ row.link_fb }}"> <img src="/images/fb.png" alt=""></a>{% endif %}
							{# <span class="views">{{ row.biblioevents.id }}</span> #}
						</div>
					{% endif %}
				{% endfor %}
			{% else %}
				<!--
				<h3>У {% if band.name_genitive %}{{ band.name_genitive }}{% elseif  band.name_genitive is empty %} музыкальной группы {% endif %}  нет событий!</h3>
				-->
			{% endif %}

			<span class="clearfix"></span>
			<div class='content'>
				{{ band.info|raw }}



				{% if band.link_yandex or band.link_apple or band.link_spotify %} <h3>Слушать музыку {{ band.name }}</h3>{% endif %}
				{% if band.link_yandex %}<a href='{{ band.link_yandex }}'>Яндекс.Музыка</a><br>{% endif %}
				{% if band.link_apple %}<a href='{{ band.link_apple }}'>Apple Music</a><br>{% endif %}
				{% if band.link_spotify %}<a href='{{ band.link_spotify }}'>Spotify</a><br>{% endif %}


				
			</div>
		</div>

		<div class="clear"></div>

		<div class="container">
			<div class="row">
				{% if band.link_yt or band.link_vk or band.link_fb or band.link_insta or band.link_tg%} <h3 class='text-left'>Ссылки на социальные сети. Подписывайтесь!</h3>{% endif %}
				<div class="clear"></div>
				{% if band.link_yt %} 
				<div style=" width: 20%; min-width: 40px; max-width: 80px; float: left; margin: 5px;">
					<center><a href="{{ band.link_yt }}" title="youtube"><img width="80%" src="https://harplivemusic.ru/assets/images/icon-yt.png" alt="youtube"></a></center>
				</div>
				{% endif %}
				{% if band.link_fb %}
				<div style=" width: 20%; min-width: 40px; max-width: 80px; float: left; margin: 5px;">
					<center><a href="https://facebook.com/{{ band.link_fb }}" title="facebook"><img width="80%" src="https://harplivemusic.ru/assets/images/icon-fb.png" alt="facebook"></a></center>
				</div>
				{% endif %}
				{% if band.link_vk %}
				<div style=" width: 20%; min-width: 40px; max-width: 80px; float: left; margin: 5px;">
					<center><a href="https://vk.com/{{ band.link_vk }}" title="Вконтакте"><img width="80%" src="https://harplivemusic.ru/assets/images/icon-vk.png" alt="Вконтакте"></a></center>
				</div>
				{% endif %}
				<!--{% if band.link_insta %}
				<div style=" width: 20%; min-width: 40px; max-width: 80px; float: left; margin: 5px;">
					<center><a href="https://instagram.com/{{ band.link_insta }}" title="instagram">
						<img width="80%" src="https://harplivemusic.ru/assets/images/icon-instagram.png" alt="instagram"></a></center>
				</div>
				{% endif %} -->
				{% if band.link_tg %}
				<div style=" width: 20%; min-width: 40px; max-width: 80px; float: left; margin: 5px;">
					<center><a href="https://t.me/{{ band.link_tg }}" title="telegram">
						<img width="80%" src="https://harplivemusic.ru/assets/images/icon-telegram.png" alt="telegram"></a></center>
				</div>
				{% endif %}
			</div>
		</div>
		<div class="clear"></div>
		<div class="content-block">
			{% if band.video1 or band.video2 or band.video3 %}
			<h2>Ролики и видео с концертов</h2>
				<div class="row video-row">
					{% if band.video1 and band.video2 and band.video3 %}
						<div class="col-xs-12 col-lg-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video1 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div> 	
						<div class="col-xs-12 col-lg-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video2 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div> 	
						<div class="col-xs-12 col-lg-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video3 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div> 	

					{% elseif band.video1 and band.video2 and (band.video3 is empty) %}
						<div class="col-xs-12 col-lg-4 col-lg-offset-2">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video1 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div> 	
						<div class="col-xs-12 col-lg-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video2 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay;  encrypted-media" allowfullscreen></iframe>
						</div>


					{% elseif band.video1 and (band.video2 is empty) and (band.video3 is empty) %}
						<div class="col-xs-12 col-lg-4 col-lg-offset-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video1 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div> 	
					{% elseif (band.video1 is empty) and band.video2 and (band.video3 is empty) %}
						<div class="col-xs-12 col-lg-4 col-lg-offset-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video2 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div>
					{% elseif (band.video1 is empty) and (band.video2 is empty) and band.video3 %}
						<div class="col-xs-12 col-lg-4 col-lg-offset-4">
							<iframe width="360" height="200" src="https://www.youtube.com/embed/{{ band.video3 }}?rel=0&amp;controls=0&amp;showinfo=0" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
						</div>
					{% endif %}
				</div>
			{% endif %}
			<div class="text-left">

				{% if band.biography %} <h3>Биография {{ band.name_ginitive }}</h3>
				 <div>{{ band.biography | raw}}</div>
			{% endif %}

			<!--{% if band.rider|raw %}
				<h4 style="font-size: 2em!important; ">Райдер {{ band.name_ginitive }}</h4>
				{{ band.rider|raw }}
			{% endif %}	-->
			{% if band.link_photo %}<noindex><a rel="nofollow" href="{{band.link_photo}}">фотографии</a></noindex>{% endif %}

			</div>
		</div>
	</div><!-- end section bloc -->

<!-- right block --> 
	<div class="sidebar-block">
		<div class="user-go">
			<h2>Вливайся<br><small>в </small>iGo<small>Event и</small></h2>
			<div class="advantage">
				<img src="/images/ico-heart-yellow.svg">
				<p>ВЫБИРАЙ ЛУЧШЕЕ<br><span>и добавляй в избранное только то, что нравится </span></p>
			</div>
			<div class="advantage">
				<img src="/images/ico-ringer-yellow.svg">
				<p>БУДЬ В КУРСЕ<br>ВСЕХ СОБЫТИЙ<br><span>iGo всегда напомнит</span></p>
			</div>
			<div class="advantage">
				<img src="/images/ico-messages-yellow.svg">
				<p>ДЕЛИСЬ СВОИМ<br>ВПЕЧАТЛЕНИЕМ<br><span>твои комментарии всегда ценят на iGo</span></p>
			</div>
		</div>
	</div>
<!-- end right block -->  
	


</div> <!-- end section-block -->



