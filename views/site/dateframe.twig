<h2>Купить билет</h2>

{% for row in events %}
	<p><a id="{{ row.id }}" class="widget_button">Купить билет - {{ row.date|date('d.m.Y H:i') }}</a></p>
{% endfor %}

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.1.0/jquery.min.js"></script>
<script type="text/javascript">

    $(function(){
        $('.widget_button').click(function() {
        	var id = this.id;
            $.ajax({
                type: 'get',
                url: "http://devcrm.goodrepublic.ru/site/formframe",
                data: {'id': this.id},
                response: 'text',
                success: function(data){
                    $('body').append(data);
                },
            })
            console.log(id);
        });
    });

</script>



<style type="text/css">
	h2 {
		position: relative;
		width: 100%;
		padding: 0;
		margin: 0;
		text-align: left;
		color: #47095b;
		font-weight: bold;
		font-size: 40px;
		font-family: 'Open Sans Condensed', sans-serif;
	}


	.widget_button {
		font-weight: 700;
		background-color: #0970c0;
		text-decoration: none!important;
		display: inline-block;
		border: 0!important;
		color: #fff!important;
		border-radius: 3px;
		line-height: 1;
		font-family: "HelveticaNeue",HelveticaNeue,Arial,sans-serif;
		font-size: 18px;
		padding: 13px 17px;
		background-image: none;
	}

</style>
