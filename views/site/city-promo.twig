		<div class="event-row">
			{% if date == 'past' %}
				<h2>Прощедшие события</h2>
			{% endif %}

			{% if biblioevents %}
				{% for row in biblioevents %}
					{% if row.image and row.oneactiveevent.status_promo >= 1 %}

						<div class="event" style="height: 500px!important;">
							
							<a class="img-event" href="/{{ city.alias }}/event/{% if row.alias %}{{ row.alias }}{% else %}{{ row.id }}{% endif %}{% if iuser.username %}?utm_source=partner&utm_medium={%if iuser.utm_medium%}{{iuser.utm_medium}}{%else%}u{{iuser.id}}{%endif%}{%endif%}">
			 					{# <span class="comments">12</span><span class="like">410</span> #}
								<img src="/uploads/users/{{ row.img.imgrazdel }}">
							</a>
							{# <span class="type-event">категория</span> #}
							<a class="title-event" href="/{{ city.alias }}/event/{% if row.alias %}{{ row.alias }}{% else %}{{ row.id }}{% endif %}{% if iuser.username %}?utm_source=partner&utm_medium={%if iuser.utm_medium%}{{iuser.utm_medium}}{%else%}u{{iuser.id}}{%endif%}{%endif%}">
								<h3>{{ row.name }} {# <small>6+</small> #}</h3>
							</a>
							{% if date %}
								{% if date != 'past' %}
									{% for event in row.events %}
										{% if event.date|date('Y-m-d') == date %}
											<span class="point">{{ event.date|date('d.m.Y ') }} в {{ event.date|date('H:i') }}</span> 

										{% endif %}
										{% if row.link_vk %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ event.link_vk }}"> <img src="/images/vk.png" alt=""></a>{% endif %}
										{% if row.link_vk %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ event.link_vk }}"> <img src="/images/vk.png" alt=""></a>{% endif %}
										{% if row.link_kg %}<a style="float: right; margin-right: 20px;"class="soc" href="https://vk.com/{{ event.link_kg }}"> <img src="/images/kg.png" alt="">kg</a>{% endif %}
							{% if row.link_fb %}<a style="float: right; margin-right: 20px;"class="soc" href="{{ event.link_fb }}"> <img src="/images/fb.png" alt=""></a>{% endif %}
									{% endfor %}
								{% endif %}
							{% else %}
								<span class="point">{{row.places.name}}<br>
								{{row.places.address}}<br>
								{{ row.oneactiveevent.date|date('d.m.Y ') }} в {{ row.oneactiveevent.date|date('H:i') }}</span><br>
								
								{% if row.oneactiveevent.link_vk %}<a style="float: right; margin: 0 5px 0 0; "class="soc" href="https://vk.com/{{ row.oneactiveevent.link_vk }}"> <img src="/images/vk.png" width="70%" alt=""></a>{% endif %}
								{% if row.oneactiveevent.link_fb %}<a style="float: right; margin: 0 5px 0 0;"class="soc" href="{{ row.oneactiveevent.link_fb }}"> <img width="70%" src="/images/fb.png" alt=""></a>{% endif %}
								{% if row.oneactiveevent.link_kg %}<a style="float: right; margin: 0 5px 0 0;"class="soc" href="{{ row.oneactiveevent.link_kg }}"> <img width="70%" src="/images/kg.png" alt=""></a>{% endif %}
							{% endif %}
							<div class="clear"></div>
							{% if iuser.id %} <textarea style="width: 100%!important; border: 1px solid red;">{{ row.name }}
{{ row.oneactiveevent.date|date('d.m.Y ') }} в {{ row.oneactiveevent.date|date('H:i') }}

{% if row.oneactiveevent.info %} {{row.oneactiveevent.info }} {%else%}{{ row.info }}{%endif%}


https://igoevent.com/{{ city.alias }}/event/{% if row.alias %}{{ row.alias }}{% else %}{{ row.id }}{% endif %}{% if iuser.username %}?utm_source=partner&utm_medium={%if iuser.utm_medium%}{{iuser.utm_medium}}{%else%}u{{iuser.username}}{%endif%}{%endif%}


Место: {{row.places.name}}
Адрес: {{row.places.address}}

{% if row.img.vk %} https://vk.com/{{ row.img.vk }}
{% endif%}{{ row.link_vk_audio }}
{{ row.link_vk_img }}

							</textarea> {% else %}<span style="color: red!important">Авторизуйтесь и будет текст поста!!</span> {% endif %}
