<div class="container title-section">
	<div class="row">
		<div class="title-geo">
			<h1>Я иду <small class="geo-in-this">в {{ city.name }}</small></h1>
			<ul class="geo-in-row">
				{% for row in cities %}
					<li class="city {% if row.alias == city.alias %}active{% endif %}"><a href="/{{ row.alias }}">{{ row.name }}</a></li>
				{% endfor %}
			</ul>
		</div>

		<ul class="week-row">
			{% set mnths = ['','янв','фев','мар','апр','мая','июн','июл','авг','сен','окт','ноя','дек'] %}
			{% set week = ['','пн','вт','ср','чт','пт','сб','вс'] %}
			{% for i in 0..6 %}
				<li>
					<a href="/{{ city.alias }}?date={{ mon|date('Y-m-d') }}" {% if mon|date('Y-m-d') == now|date('Y-m-d') %} class="cred"{% endif %}>
						{{ mon|date('d') }}
						<span>{{ mnths[mon|date("n")] }}</span>
						<small {% if i > 4 %}class="weekend"{% endif %}>{{ week[i + 1] }}</small>
					</a>
				</li>
				{% set mon = [mon|date_modify("+1 day")|date('Y-m-'), mon|date_modify("+1 day")|date('d')]|join %}
			{% endfor %}
		</ul>
	</div>
</div>




