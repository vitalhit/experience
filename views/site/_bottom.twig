{% if ads %}
	<h2 class="tal">Рекомендации</h2>
	<div class="clear"></div>
	{% set i = 0 %}
	{% for row in ads %}
		{% if loop.index > 5 and i < 8 %}
			{% set i = i + 1 %}
			<div class="col-xs-12 col-lg-3">
				<div class="event">
					<a class="img-event" href="/{{ row.cities.alias }}/event/{% if row.alias %}{{ row.alias }}{% else %}{{ row.id }}{% endif %}">
						<img src="/web/uploads/users/{{ row.img.imgrazdel }}" class="img-responsive">
					</a>
					<a class="title-event" href="/{{ row.cities.alias }}/event/{% if row.alias %}{{ row.alias }}{% else %}{{ row.id }}{% endif %}">
						<h4>{{ row.name }}</h4>
					</a>
				</div>
			</div>
		{% endif %}
	{% endfor %}
{% endif %}