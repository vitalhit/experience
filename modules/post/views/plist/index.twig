{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
              
                <div class="col-xs-12 col-lg-12">
                    <h2>All plists</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xs-12 col-lg-12">
        
        <a class="btn btn-success btn-sm" href="/post/plist/create"> добавить plist <span class="glyphicon glyphicon-plus small"></span></a>
        <br><br>
        <table class="tb stacktable">
            <tr>

                <td>id</td>
                <td>stop</td>
                <td>public_vk_id</td>
                <td>time</td>
                <td>name</td>
                <td>goal</td>
                <td colspan="2">current_post</td>
                <td>pt</td><td>pa</td><td>pp</td><td>pv</td><td>pq</td>
            </tr>
            {% for one in all %}
            <tr>
                <td><a href="/post/plist/update?id={{ one.id}}">{{ one.id}}</a></td>
                <td>{{ one.stop}}</td>
                <td>{{ one.public_vk_id}}</td>
                <td>{{ one.time}}</td>
                <td>{% if one.stop < 0 %}<s><a href="/post/plist/view?id={{ one.id}}">{{ one.name}}</a></s>{%else %}<a href="/post/plist/view?id={{ one.id}}">{{ one.name}}</a>{%endif%}</td>
                <td>{{ one.goal}}</td>
                <td>{{ one.current_post}}</td>
                <td><a class="btn btn-success btn-xs" href="/post/plist/addpost?plist_id={{one.id}}">+post</a></td>
                            
                <td>
                {{ one.current_ptext}}</td><td>{{ one.current_paudio}}</td><td>{{ one.current_pphoto}}</td><td>{{ one.current_pvideo}}</td><td>{{ one.current_pquote}}</td>
                <td>
                </td>
            </tr>
            {% endfor %}
        </table>
    </div>
</div>

    {{link_pager_widget({
        'pagination': pages
    }) }}



    <div class="popup end popup_d"></div>

    <div class="overlay"></div>

