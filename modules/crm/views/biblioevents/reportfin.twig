{% set mnths = ['','января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'] %}

<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<button type="button" class="left_toggle"><span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span></button>
			<h2>{{ biblioevent.name }} | {{ biblioevent.cities.name }}</h2>
			<!-- <span class="tal mt0">{{ biblioevent.categoryevents.category }} </span> -->
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/event_step.twig', {'biblioevent' : model, 'user' : user}) | raw }}
	</div>
	<div class="col-xs-12 col-lg-9">
		<div class="newblo">
			<div class="row">
				<div class="col-xs-12 col-lg-3 mb20">
					<form method="get">
						<input type="hidden" name="id" value="{{ biblioevent.id }}">
						<select name="event_id" class="form-control" onchange="this.form.submit()">
							<option value="">Все даты</option>
							{% for row in dates %}
								<option value="{{ row.id }}" {% if row.id == event_id %}selected{% endif %}>{{ row.date|date("j") }} {{ mnths[row.date|date("n")] }} {{ row.date|date("Y") }} - {{ row.date|date("H:i") }}</option>
							{% endfor %}
						</select>
					</form>
					<small> {% if event_id %}<a class="btn-success small btn btn-xs" href="/crm/events/update?id={{event_id}}"><span class="glyphicon glyphicon-pencil"></span></a> <a class="btn-success small btn btn-xs" href="/crm/finance/create?event_id={{event_id}}"><span class="glyphicon glyphicon-rub"></span></a> <a class="btn-success small btn btn-xs" href="/crm/eventdeal/create?event_id={{event_id}}&deal_id=4&media_id=2&newsmaker_id=36&percent=20&status=1&date_closed={{event.date|date("Y-m-d H:i")}}&date_create=&info=%D0%B4%D0%BE%D0%B1%D0%B0%D0%B2%D0%BB%D0%B5%D0%BD%D0%BE%20%D0%B8%D0%B7%20events"><span class="glyphicon glyphicon-briefcase"></span></a> 
				</div>
				<div class="col-xs-4 col-lg-3">
					<div class="col-xs-12 col-lg-8 p0">
						<h4 class="itog c_yell tac">{{ ticket_nopay_sum|number_format(0, '.', ' ') }}<span>брони</span> </h4>
					</div>
					<div class="col-xs-12 col-lg-4 p0">
						<h4 class="itog c_yell tac">{{ ticket_nopay_count }} <span>шт</span> </h4>
					</div>
				</div>
				<div class="col-xs-4 col-lg-3 bl">
					<div class="col-xs-12 col-lg-8 p0">
						<h4 class="itog c_red tac">{{ ticket_back_sum|number_format(0, '.', ' ') }}<span>возвраты</span> </h4>
					</div>
					<div class="col-xs-12 col-lg-4 p0">
						<h4 class="itog c_red tac">{{ ticket_back_count }} <span>шт</span> </h4>
					</div>
				</div>
				<div class="col-xs-4 col-lg-3  bl">
					<div class="col-xs-12 col-lg-8 p0">
						<h4 class="itog c_green tac">{{ ticket_pay_sum|number_format(0, '.', '') }}<span>отплаты<br><small>- {{  contract.percent }}% - {{  contract.tax }}% = {{ ticket_pay_sum * ( 100 - contract.percent )/100 * ( 100 - contract.tax)/100  }}</small></span> </h4>
					</div>
					<div class="col-xs-12 col-lg-4 p0">
						<h4 class="itog c_green tac">{{ ticket_pay_count }} <span>шт</span> </h4>
					</div>
				</div>
			</div>
		</div>
		
		<br>
		<div class="newblo">
			<div class="row">
				<div class="col-xs-12 col-lg-9"> 
					<a class="din btn btn-success" href="/crm/todos/smm?id={{event_id}}">smm</a> 
					<a class="din btn btn-success" href="/crm/todos/placer?id={{event_id}}">placer</a>
					<a class="din btn btn-success" href="/crm/todos/artist?id={{event_id}}">artist</a>


				</div>
			</div>
		</div>


		{% for row in dates %}
			<small><a class="din btn btn-{% if row.id == event_id %}success{%else%}info{% endif %}" href="/crm/events/update?id={{row.id}}">{{ row.date|date("j") }} {{ mnths[row.date|date("n")] }} {{ row.date|date("Y") }}</a></small>
		{% endfor %}

		<div class="tbmob visible-xs">
			{% for tik in tickets %}
				<div class="newblo{% if tik.status == 5 or tik.summa == 0 %} gtop {% elseif tik.status == 8 %} dtop {% elseif tik.status == 7 %} rtop {% else %} ytop {% endif %}">
					<div class="col-xs-4"><span class="mini"># {{ tik.id }}</span></div>
					<div class="col-xs-4"><span class="mini">Куп {{ tik.date|date('d.m') }}</span></div>
					<div class="col-xs-4"><span class="mini">Дата {{ tik.events.date|date('d.m') }}</span></div>
					<div class="clear"></div>

					<div class="col-xs-6"><span class="mini">{{ tik.persons.mail }} </span><br>
						<a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.name }} {{ tik.persons.second_name }}</a>
					</div>
					<div class="col-xs-6"><span class="mini"><a href="tel:{{ tik.persons.phone }}">{{ tik.persons.phone }}</a>(<a href="https://wa.me/{{ tik.persons.phone }}?text=Здравствуйте. {{ tik.persons.name }} {{ tik.persons.second_name }}. Пишу вам по поводу {{ biblioevent.name }}. http://igoevent.com/{{ biblioevent.cities.alias }}/event/{{ biblioevent.alias }}?utm_source=whatsapp&utm_medium=igoevent&utm_campaign=massage">wap</a>)</span><br>
						
					</div>
					<div class="clear"></div>

					<div class="col-xs-12">{{ tik.seats.name }}</div>
					<div class="clear"></div>

					<div class="col-xs-4"><b>{{ tik.money }}</b>р</div>
					<div class="col-xs-4">* <b>{{ tik.count }}</b></div>
					<div class="col-xs-4">= <b>{{ tik.summa }}</b>р</div>
					<div class="clear"></div>

					<div class="col-xs-2 tac">{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</div>
					<div class="col-xs-4 tac" tag="{{ tik.status_come }}">{% if tik.status_come == 1 %}Пришел{% elseif tik.status_come == 2 %}Нет{% endif %}</div>
					<div class="col-xs-3 tac"><a class="comeinmob" tag="{{ row.biblioevent.id }}" id="{{ tik.id }}"><span class="glyphicon glyphicon-ok-circle"></span></a></div>
					<div class="col-xs-3 tac"><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></div>
				</div>
			{% endfor %}
		</div>
		{% if event_id %}
		{{ this.render('/module/block_finance_report_event.twig', {'alleventfinances' : alleventfinances}) | raw }}

		{{ this.render('/module/block_finance_report_eventdeal.twig', 
		{	'eventdeal_profit' : eventdeal_profit, 'eventdeal_tickets' : eventdeal_tickets, 'tickets' : tickets })| raw }}
		{% endif %}
	</div> 
</div>


<script type="text/javascript">
$(document).ready(function() {

		$('.steps .guest').addClass('active');

	// Меняем статус что гость пришел
	$(document).on('click', ".comein", function(){
		var ticketid = $(this).attr('id');
		var biblioeventid = $(this).attr('tag');
		var td = $(this).parent('td').prev();
		console.log(td);
		$.ajax({
			type: 'get',
			url: "/crm/biblioevents/comein",
			data: {'ticketid': ticketid, 'biblioeventid': biblioeventid},
			response: 'text',
			success: function(data){
				$('.user').html(data);

				if ($(td).attr('tag') == 1) {
					$(td).html('Нет');
					$(td).attr('tag', 2);
				}else if ($(td).attr('tag') == 2) {
					$(td).html('Да');
					$(td).attr('tag', 1);
				}else if ($(td).attr('tag') == 0) {
					$(td).html('Да');
					$(td).attr('tag', 1);
				}
			}
		})
	});

	// Меняем статус что гость пришел МОБИЛЬНАЯ
	$(document).on('click', ".comeinmob", function(){
		var ticketid = $(this).attr('id');
		var biblioeventid = $(this).attr('tag');
		var td = $(this).parent('div').prev();
		console.log(td);
		$.ajax({
			type: 'get',
			url: "/crm/biblioevents/comein",
			data: {'ticketid': ticketid, 'biblioeventid': biblioeventid},
			response: 'text',
			success: function(data){
				$('.user').html(data);

				if ($(td).attr('tag') == 1) {
					$(td).html('Нет');
					$(td).attr('tag', 2);
				}else if ($(td).attr('tag') == 2) {
					$(td).html('Пришел');
					$(td).attr('tag', 1);
				}else if ($(td).attr('tag') == 0) {
					$(td).html('Пришел');
					$(td).attr('tag', 1);
				}
			}
		})
	});
});
	</script>



