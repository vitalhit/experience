</div> {# закрыть div для container #}
<div class="col-xs-12 col-lg-12">
	<div class="newblo">
		<h2>Все билеты из всех событий</h2>
	</div>
</div>
<div class="col-xs-12 col-lg-2 left_blo">
	{{ this.render('/module/event_step.twig', {'biblioevent' : model, 'user' : user}) | raw }}
</div>

<div class="col-xs-12 col-lg-10">
	<div class="newblo">
		<div class="row">
			<div class="col-xs-4 col-lg-3">
				<div class="col-xs-12 col-lg-8 p0">
					<h4 class="itog c_yell tac">{{ tickets|length }} </h4>
				</div>
				<div class="col-xs-12 col-lg-4 p0">
					<h4 class="itog c_yell tac"><span>всего</span> </h4>
				</div>
			</div>
			<div class="col-xs-4 col-lg-3 bl">
				<div class="col-xs-12 col-lg-8 p0">
					<h4 class="itog c_yell tac">{{ ticket_nopay_sum|number_format(0, '.', ' ') }}<span>брони</span> </h4>
				</div>
				<div class="col-xs-12 col-lg-4 p0">
					<h4 class="itog c_yell tac">{{ ticket_nopay_count }} <span>шт</span> </h4>
				</div>
			</div>
			<div class="col-xs-4 col-lg-3 bl">
				<div class="col-xs-12 col-lg-8 p0">
					<h4 class="itog c_red tac">{{ ticket_back_sum|number_format(0, '.', ' ') }}<span>возвраты</span> </h4>
				</div>
				<div class="col-xs-12 col-lg-4 p0">
					<h4 class="itog c_red tac">{{ ticket_back_count }} <span>шт</span> </h4>
				</div>
			</div>
			<div class="col-xs-4 col-lg-3  bl">
				<div class="col-xs-12 col-lg-8 p0">
					<h4 class="itog c_green tac">{{ ticket_pay_sum|number_format(0, '.', ' ') }}<span>отплаты</span> </h4>
				</div>
				<div class="col-xs-12 col-lg-4 p0">
					<h4 class="itog c_green tac">{{ ticket_pay_count }} <span>шт</span> </h4>
				</div>
			</div>
		</div>
	</div>
	<table class="tb hidden-xs">
		<tr>
			<th>Событие<br>Дата</th>
			<th>Гость</th>
			<th>Цена</th>
			<th>Статус</th>
			<th></th>
			<th></th>
			<th></th>
			<th></th>
		</tr>
		{% for tik in tickets %}
			<tr class="{% if tik.status == 5 or tik.summa == 0 %} green {% elseif tik.status == 8 %} black {% elseif tik.status == 7 %} red {% else %} yellow {% endif %}">
				<td>{{ tik.biblioevent_name }}<br>{{ tik.event_date|date('d.m H:i') }} / {{ tik.seats.name }} <a href='/site/ticket?barcode={{ tik.barcode }}'>{{ tik.id }}</a> | <a href='https://yookassa.ru/my/payments?search={{ tik.order_id }}'>{{ tik.order_id }}</a> | {{ tik.date|date('d.m H:i') }}</td>
				<td><a target="_blank" href="/crm/persons/view?id={{ tik.user_id }}">{{ tik.name }} {{ tik.secondname }}</a><br><span>{{ tik.email }}<br>{{tik.phone}}</span><br>
					
				</td>
				
				<td class="tar">{{ tik.money }}</td>
				<td>
					<p class="çolor">
						{% if tik.status == 5 %} Оплачен {% elseif tik.status == 8 %} Отмена {% elseif tik.status == 3 %} Не оплачен {% elseif tik.status == 1 %} 
							{% if tik.summa == 0 %}
								Регистрация{% else %}Бронь
							{% endif %}
						{% endif %}
					</p>
				</td>
				<td>{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</td>
				<td tag="{{ tik.status_come }}">{% if tik.status_come == 1 %}Пришел{% elseif tik.status_come == 2 %}Нет{% endif %}</td>
				<td><a class="comein" tag="{{ row.biblioevent.id }}" id="{{ tik.id }}"><span class="glyphicon glyphicon-ok-circle"></span></a></td>
				<td><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></td>
			</tr>
		{% endfor %}
		<tr><td colspan="12"><p><b>СНЯТЫЕ БРОНИ</b></p></td></tr>
		{% for tik in row.dead %}
			<tr class="grey">
				<td>{{ tik.events.date|date('d.m H:i') }}</td>
				<td>{{ tik.date|date('d.m H:i') }}</td>
				<td><span>{{ tik.persons.mail }} </span><br><a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.name }} {{ tik.persons.secondname }}</a></td>
				
				<td class="tar">{{ tik.money }}</td>
				<td class="tar">{{ tik.count }}</td>
				<td class="tar">{{ tik.summa }}</td>
				<td></td>
				<td>{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</td>
				<td tag="{{ tik.status_come }}">{% if tik.status_come == 1 %}Пришел{% elseif tik.status_come == 2 %}Нет{% endif %}</td>
				<td>{% if tik.seats.afterpay == 1 %}<a target="_blank" href="/site/pay?order_id={{ tik.order_id }}"><span class="glyphicon glyphicon-rub"></span></a>{% else %} - {% endif %}</td>
				<td><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></td>
			</tr>
		{% endfor %}
	</table>

	<div class="tbmob visible-xs">
		{% for row in all %}
			<div class="newblo">
				<h3 class="m0"><a href="/crm/biblioevents/view?id={{ row.biblioevent.id }}">{{ row.biblioevent.name }}</a></h3>
			</div>
			{% for tik in row.tickets %}
				<div class="newblo{% if tik.status == 5 or tik.summa == 0 %} gtop {% elseif tik.status == 8 %} dtop {% elseif tik.status == 7 %} rtop {% else %} ytop {% endif %}">
					<div class="col-xs-4"><span class="mini"># {{ tik.id }}</span></div>
					<div class="col-xs-4"><span class="mini">Куп {{ tik.date|date('d.m') }}</span></div>
					<div class="col-xs-4"><span class="mini">Дата {{ tik.events.date|date('d.m') }}</span></div>
					<div class="clear"></div>

					<div class="col-xs-12"><span class="mini">{{ tik.persons.mail }} </span><br>
						<a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.name }} {{ tik.persons.secondname }}</a>
					</div>
					<div class="clear"></div>

					<div class="col-xs-4"><b>{{ tik.money }}</b>р</div>
					<div class="col-xs-4">* <b>{{ tik.count }}</b></div>
					<div class="col-xs-4">= <b>{{ tik.summa }}</b>р</div>
					<div class="clear"></div>

					<div class="col-xs-2 tac">{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</div>
					<div class="col-xs-4 tac" tag="{{ tik.status_come }}">{% if tik.status_come == 1 %}Пришел{% elseif tik.status_come == 2 %}Нет{% endif %}</div>
					<div class="col-xs-3 tac"><a class="comeinmob" tag="{{ row.biblioevent.id }}" id="{{ tik.id }}"><span class="glyphicon glyphicon-ok-circle"></span></a></div>
					<div class="col-xs-3 tac"><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></div>
				</div>
			{% endfor %}
			<div class="newblo">
				<h3 class="m0"><p><b>СНЯТЫЕ БРОНИ</b></p></h3>
			</div>
			{% for tik in row.dead %}
				<div class="newblo grtop">
					<div class="col-xs-4"><span class="mini"># {{ tik.id }}</span></div>
					<div class="col-xs-4"><span class="mini">Куп {{ tik.date|date('d.m') }}</span></div>
					<div class="col-xs-4"><span class="mini">Дата {{ tik.events.date|date('d.m') }}</span></div>
					<div class="clear"></div>

					<div class="col-xs-12"><span class="mini">{{ tik.persons.mail }} </span><br>
						<a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.name }} {{ tik.persons.secondname }}</a>
					</div>
					<div class="clear"></div>
					<div class="col-xs-4"><b>{{ tik.money }}</b>р</div>
					<div class="col-xs-4">* <b>{{ tik.count }}</b></div>
					<div class="col-xs-4">= <b>{{ tik.summa }}</b>р</div>
					<div class="clear"></div>

					<div class="col-xs-2 tac">{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</div>
					<div class="col-xs-4 tac"></div>
					<div class="col-xs-3 tac">{% if tik.seats.afterpay == 1 %}<a target="_blank" href="/site/pay?order_id={{ tik.order_id }}"><span class="glyphicon glyphicon-rub"></span></a>{% else %} - {% endif %}</div>
					<div class="col-xs-3 tac"><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></div>
				</div>
			{% endfor %}
		{% endfor %}
	</div>
</div>
{# открыть div для container #}
<div> 



	<script type="text/javascript">
		$(document).ready(function() {

			$('.steps .guest').addClass('active');

	// Меняем статус что гость пришел
			$(document).on('click', ".comein", function(){
				var ticketid = $(this).attr('id');
				var biblioeventid = $(this).attr('tag');
				var td = $(this).parent('td').prev();
				console.log(td);
				$.ajax({
					type: 'get',
					url: "/crm/biblioevents/comein",
					data: {'ticketid': ticketid, 'biblioeventid': biblioeventid},
					response: 'text',
					success: function(data){
						$('.user').html(data);

						console.log($(td).attr('tag'));

						if ($(td).attr('tag') == 1) {
							$(td).html('Нет');
							$(td).attr('tag', 2);
						}else if ($(td).attr('tag') == 2) {
							$(td).html('Пришел');
							$(td).attr('tag', 1);
						}else if ($(td).attr('tag') == 0) {
							$(td).html('Пришел');
							$(td).attr('tag', 1);
						}
					}
				})
			});

	// Меняем статус что гость пришел МОБИЛЬНАЯ
			$(document).on('click', ".comeinmob", function(){
				var ticketid = $(this).attr('id');
				var biblioeventid = $(this).attr('tag');
				var td = $(this).parent('div').prev();
				console.log(td);
				$.ajax({
					type: 'get',
					url: "/crm/biblioevents/comein",
					data: {'ticketid': ticketid, 'biblioeventid': biblioeventid},
					response: 'text',
					success: function(data){
						$('.user').html(data);

						console.log($(td).attr('tag'));

						if ($(td).attr('tag') == 1) {
							$(td).html('Нет');
							$(td).attr('tag', 2);
						}else if ($(td).attr('tag') == 2) {
							$(td).html('Пришел');
							$(td).attr('tag', 1);
						}else if ($(td).attr('tag') == 0) {
							$(td).html('Пришел');
							$(td).attr('tag', 1);
						}
					}
				})
			});
		});
	</script>


