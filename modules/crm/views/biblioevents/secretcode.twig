{{ use('/yii/widgets') }}

<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<h2>Секретные коды для «{{ biblioevent.name}}»</h2>
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/event_step.twig', {'biblioevent' : biblioevent, 'user' : user}) | raw }}
	</div>
	<div class="col-xs-12 col-lg-8 ">

		<p><a class="btn btn-success" href="/crm/biblioevents/secretcodecreate?biblioevent_id={{ biblioevent.id}}">Создать секретное слово</a></p>
		<table class="tb stacktable">
            <tr>
                <td>id</td>
                <td>secretcode</td>
                <td>title</td>
            </tr>
            {% for secretcode in secretcodes %}
            <tr>
                <td><span>{{ secretcode.id }}</span></td>
                <td><span><a href="/crm/biblioevents/secretcodeupdate?id={{ secretcode.id }}">{{ secretcode.code }}</a></span></td>
                <td>
                    <span>{{ secretcode.title }}</span>
                    <p>{{ secretcode.info }}</p>
                </td>
            </tr>
            {% endfor %}
		</table>
	</div>
</div>


<script type="text/javascript">
	$('.steps .inst').addClass('active');
</script>