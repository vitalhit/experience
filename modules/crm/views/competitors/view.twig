    <div class="row">
    <div class="col-xs-12 col-lg-3 left_blo">
        <div class="stiky">
            <div class="newblo">
                {% if competitor.image %}
                    <img src="/uploads/users/{{ competitor.image }}" class="img-responsive img-circle">
                {% else %}
                    <img src="/images/noimage.png" class="img-responsive img-circle">
                {% endif %}
                <h2 class="mt0">{% if competitor.name %}{{ competitor.name }} {{ competitor.second_name }}{% endif %}</h2>
                <a href="/crm/competitors/update?id={{ competitor.id }}" class="btn btn-primary ma w120">Редактировать</a>
                <h4>User_id: {{ user_id }}<br>Профиль id: {{ competitor.id }}</h4>
                <p><b>Статус:</b> {{ competitor.status }}</p>
                <p><b>Дата рождения:</b> {{ competitor.birthday|date('d.m.Y') }}</p>
                <p><b>E-mail:</b> {{ competitor.mail }}</p>
                <p><b>Телефон:</b> {{ competitor.phone }}</p>
                <p><b>Пол:</b> {% if competitor.sex == 0 %} женщина {% else %} мужчина {% endif %} </p>
                <p><b>Группы:</b> {{ competitor.groups }}</p>
                <p><b>Откуда:</b> {{ competitor.froms.url }}</p>
                <p><b>Получать письма:</b> {% if competitor.sendmail == 1 %} Да {% else %} Нет {% endif %} </p>
                <p><b>Пожелания:</b> {{ competitor.vishes }}</p>
            </div>
            {% if competitor.info %}
                <div class="newblo"><p>{{ competitor.info }}</p></div>
            {% endif %}
        </div>
    </div>
    <div class="col-xs-12 col-lg-9">
        <div class="newblo">
            <div class="row">
                <div class="col-xs-3"><a href="/crm/competitors/">клиенты</a> <h3 class="itog"></h3></div>
                <div class="col-xs-3"><h3 class="itog"></h3></div>
                <div class="col-xs-3"><h3 class="itog"></h3></div>
                <div class="col-xs-3"><h3 class="itog"></h3></div>
            </div>
        </div>
        
