<ul class="search_result"></ul>

<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<div class="row">
				<div class="col-xs-12 col-lg-3">
					<form class="form-inline form_lite">
						<input type="text" class="form-control who" name="referal" placeholder="Фамилия гостя" autocomplete="off">
					</form>
				</div>
				<div class="col-xs-12 col-lg-7">
					<div class="row">
						<div class="col-xs-12 col-lg-4">
							<h3 class="itog">{{ summnal|number_format(0, '.', ' ') }}<span>Наличка</span></h3>
						</div>
						<div class="col-xs-12 col-lg-4">
							<h3 class="itog">{{ summbez|number_format(0, '.', ' ') }}<span>Безнал</span></h3>
						</div>
						<div class="col-xs-12 col-lg-4">
							<h3 class="itog">{{ summgr|number_format(0, '.', ' ') }}<span>igovent</span></h3>
						</div>
					</div>
				</div>
				<div class="col-xs-12 col-md-2">
					{% if smena %}
						<a class="btn btn-warning pull-right endsmena">Завершить смену</a>
					{% else %}
						<a class="btn btn-success pull-right startsmena">Начать смену</a>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/residence_step.twig', {'company' : company}) | raw }}
	</div>

	<div class="col-xs-12 col-lg-9">
		
		<div class="mini_header mt0"><span>В РЕЗИДЕНЦИИ</span></div>

		<table class="tb">
			<tbody>
				{% for row in inside|reverse %}
					<tr>
						<td><p><span>{{ row.id }}</span></p></td>
						<td class="tac">
							<img src="{% if row.image %}/uploads/users/{{ row.image }}{% else %}/web/images/noimage.png{% endif %}" class="w26 img-circle">
						</td>
						<td>
							<span>{{ row.name }} {{ row.middle_name }} </span><br>
							<a target="_blank" href="/crm/persons/view?id={{ row.id }}">{{ row.second_name }}</a>
						</td>
						<td><span>Визит</span><br>{{ row.visits|length }}</td>
						<td><span>С</span><br>{{ row.visits|last.start|date('H:i') }}</td>
						<input type="hidden" name="" class="in_time" value="{{ row.visits|last.start|date('Y/m/d H:i:s') }}">
						<td><span>В гостях</span><br><span class="normal"></span></td>
						<td>{{ row.status }}</td>
						<td>
							{% set abonementactive = 0 %}
								{% for abon in row.abonements %}
									{% if abon.status == 1 %}
										{% set abonementactive = 1 %}
										{% endif %}
									{% endfor %}

									{% if row.inside == 2 %}
										<form method="get" action="/crm/persons/endabonement">
											<input type="hidden" name="" value="/crm/persons/endabonement">
											<input type="hidden" name="uid" value="{{ row.id }}">
											<button type="submit" class="btn btn-primary">Абонемент</button>
										</form>
									{% else %}
										<form>
											<input type="hidden" name="uid" class="uid" value="{{ row.id }}">
											{% if smena %}
												<input type="button" class="endvisit btn btn-primary" value="Тариф">
											{% else %}
												<input type="button" disabled="" class="endvisit btn btn-primary" value="Тариф">
											{% endif %}
										</form>
									{% endif %}
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>


				<div class="mini_header mt20"><span>БЫЛИ СЕГОДНЯ</span></div>

				<table class="tb stacktable">
					{% for out in today %}
						<tr>
							<td><p><span>{{ out.id }}</span></p></td>
							<td class="tac">
							<img src="{% if out.image %}/uploads/users/{{ out.image }}{% else %}/web/images/noimage.png{% endif %}" class="w26 img-circle">
							</td>
							<td>
								<span>{{ out.name }} {{ out.middle_name }} </span><br>
								<a target="_blank" href="/crm/persons/view?id={{ out.id }}">{{ out.second_name }}</a>
							</td>

							<td><span>Визит</span><br>{{ out.visits|length }}</td>

							<td><span>С</span><br>{{ out.visits|last.start|date('H:i') }}</td>
							<td><span>По</span><br>{{ out.visits|last.end|date('H:i') }}</td>
							<td>{{ out.status }}</td>
							<td><span>
								{% if out.visits|last.type == 1 %}
									Нал
								{% elseif out.visits|last.type == 2 %}
									БезНал
								{% elseif out.visits|last.type == 3 or out.visits|last.type == 9 %}
									Яндекс
								{% elseif out.visits|last.type == 4 %}
									Free
								{% else %}
									-
								{% endif %}
							</span><br>
							{{ out.visits|last.money }} р
						</td>

						<td>
							<form method="get" action="/crm/persons/visit">
								<input type="hidden" name="" value="/crm/persons/visit">
								<input type="hidden" name="uid" value="{{ out.id }}">
								{% if smena %}
									<button type="submit" class="btn btn-primary">Тариф</button>
								{% else %}
									<button type="submit" disabled="" class="btn btn-primary">Тариф</button>
								{% endif %}
							</form>
						</td>
					</tr>
				{% endfor %}
			</table>

		</div>
	</div>


	<div class="popup end popup_d"></div>

	<div class="overlay"></div>



	<script type="text/javascript">

	$(function(){

		// Начинаем смену
		$(".startsmena").click(function(){
			$.ajax({
				type: 'get',
				url: "/crm/smena/formstartsmena", //Путь к обработчику
				response: 'text',
				success: function(data){
					$(".end").html(data).fadeIn(); //Выводим полученые данные в списке
				}
			})
			var myscrollpop = $(window).scrollTop();
			$('.popup.end').animate({'top': myscrollpop + 100, 'opacity': 1}, 500);
			$('.overlay').fadeIn();
		})

		// Завершаем смену
		$(".endsmena").click(function(){
			$.ajax({
				type: 'get',
				url: "/crm/smena/formendsmena", //Путь к обработчику
				response: 'text',
				success: function(data){
					$(".end").html(data).fadeIn(); //Выводим полученые данные в списке
				}
			})
			var myscrollpop = $(window).scrollTop();
			$('.popup.end').animate({'top': myscrollpop + 100, 'opacity': 1}, 500);
			$('.overlay').fadeIn();
		})


		function timeleft(){
			$(".in_time").each(function(){
				var in_time = new Date($(this).val());
				var now = new Date();
				var diff = Math.floor((now - in_time)/1000/60);
				var result = (diff/60 | 0)+ ":" +(diff%60 | 0);
				$(this).next().find("span.normal").html(result);
			});
		}

		timeleft();

		setInterval(timeleft, 50000);	


		$(".endvisit").click(function(){
			console.log($(this).prev(".uid").val());
			$.ajax({
				type: 'get',
				url: "/crm/persons/formendvisit", //Путь к обработчику
				data: {'uid':$(this).prev(".uid").val()},
				response: 'text',
				success: function(data){
					$(".end").html(data).fadeIn(); //Выводим полученые данные в списке
				}
			})
			var myscrollpop = $(window).scrollTop();
			$('.popup.end').animate({'top': myscrollpop + 100, 'opacity': 1}, 500);
			$('.overlay').fadeIn();
		})


		$(".byticket").click(function(){
			console.log($(this).prev(".uid").val());
			$.ajax({
				type: 'get',
				url: "/crm/persons/formticket", //Путь к обработчику
				data: {'uid':$(this).prev(".uid").val()},
				response: 'text',
				success: function(data){
					$(".end").html(data).fadeIn(); //Выводим полученые данные в списке
				}
			})
			var myscrollpop = $(window).scrollTop();
			$('.popup.end').animate({'top': myscrollpop + 100, 'opacity': 1}, 500);
			$('.overlay').fadeIn();
		})


		$(".sells").click(function(){
			$.ajax({
				type: 'get',
				url: "/crm/persons/formsell", //Путь к обработчику
				data: {'uid':$(this).prev(".uid").val()},
				response: 'text',
				success: function(data){
					$(".end").html(data).fadeIn(); //Выводим полученые данные в списке
				}
			})
			var myscrollpop = $(window).scrollTop();
			$('.popup.end').animate({'top': myscrollpop + 100, 'opacity': 1}, 500);
			$('.overlay').fadeIn();
		})


		//Живой поиск
		$('.who').bind("change keyup input click", function() {
			if(this.value.length >= 4){
				$.ajax({
					type: 'get',
					url: "/crm/persons/personsfind", //Путь к обработчику
					data: {'name':this.value},
					response: 'text',
					success: function(data){
						$(".search_result").html(data).fadeIn(); //Выводим полученые данные в списке
					}
				})
				$(".overlay").fadeIn();
				$(".form_lite").css({'zIndex': 9000});

			}
		})

		$(".search_result").hover(function(){
			$(".who").blur(); //Убираем фокус с input
		})

		//При выборе результата поиска, прячем список и заносим выбранный результат в input
		$(".search_result").on("click", "li", function(){
			s_user = $(this).text();
			//$(".who").val(s_user).attr('disabled', 'disabled'); //деактивируем input, если нужно
			$(".search_result, .overlay").fadeOut();
			$(".form_lite").css({'zIndex': 1000});

		})
		
	});

	</script>