<div class="row">
	<div class="col-xs-12 col-lg-3 left_blo">
		<div class="stiky">
			<div class="newblo">
				{% if person.image %}
					<img src="/uploads/users/{{ person.image }}" class="img-responsive img-circle">
				{% else %}
					<img style="width: 50%; margin-left: 25%;" src="/web/images/noimage.png" class="img-responsive img-circle">
				{% endif %}
				<h2 class="mt0">{% if person.name %}{{ person.name }} {{ person.second_name }}{% endif %}</h2>
				<h4>User_id: {{ person.user_id }}<br>Профиль id: {{ person.id }}</h4>
				<a href="/crm/persons/update?id={{ person.id }}" class="btn btn-primary ma w120">Редактировать</a>
				
				<p><b>Статус:</b> {{ person.status }}</p>
				<p><b>Дата рождения:</b> {{ person.birthday|date('d.m.Y') }}</p>
				<p><b>E-mail:</b> {{ person.mail }}</p>
				<p><b>Телефон:</b> {{ person.phone }}</p>
				<p><b>Пол:</b> {% if person.sex == 0 %} женщина {% else %} мужчина {% endif %} </p>
				<p><b>Группы:</b> {{ person.groups }}</p>
				<p><b>Откуда:</b> {{ person.froms.url }}</p>
				<p><b>Получать письма:</b> {% if person.sendmail == 1 %} Да {% else %} Нет {% endif %} </p>
				<p><b>Пожелания:</b> {{ person.vishes }}</p>
			</div>
			{% if person.info %}
				<div class="newblo"><p>{{ person.info }}</p></div>
			{% endif %}
		</div>
	</div>
	<div class="col-xs-12 col-lg-9">
		<div class="newblo">
			<div class="row">
				<div class="col-xs-3"><h3 class="itog">{{ 0 + person.sum_visits }}<span>Визиты</span></h3></div>
				<div class="col-xs-3"><h3 class="itog">{{ 0 + person.sum_tickets }}<span>Билеты</span></h3></div>
				{# <div class="col-xs-3"><h3 class="itog">{{ 0 + person.sum_sells }}<span>Покупки</span></h3></div> #}
				<div class="col-xs-3"><h3 class="itog">{{ 0 + person.sum_abonements }}<span>Абонем.</span></h3></div>
				<div class="col-xs-3"><h3 class="itog">{{ 0 + person.sum_rents }}<span>Аренды</span></h3></div>
			</div>
		</div>
		
		<div class="mini_header mt0"><span>ВИЗИТЫ <div class="badge">{{ person.visits|length }}</div></span></div>

		<div class="newblo">
			<table class="table stacktable">
				<tr>
					<td>Начало</td>
					<td>Окончание</td>
					<td>Скидка</td>
					<td>Стоимость</td>
				</tr>
				{% for row in person.visits|reverse %}
					<tr>
						<td>{{ row.start|date('d.m.Y в H:i') }}</td>
						<td>{{ row.end|date('d.m.Y в H:i') }}</td>
						<td>{{ row.discount_money }}</td>
						<td>{{ row.money }}</td>
					</tr>
				{% endfor %}
			</table>
		</div>

		{# <div class="newblo">
			<h2>Покупки <span>{{ person.sells|length }}</span> </h2>

			<table class="table stacktable">
				<tr>
					<td>Дата</td>
					<td>Стоимость</td>
					<td>Кол-во</td>
					<td>Итог</td>
				</tr>
				{% for row in person.sells|reverse %}
					<tr>
						<td>{{ row.date|date('d.m.Y в H:i') }}</td>
						<td>{{ row.price }}</td>
						<td>{{ row.count }}</td>
						<td>{{ row.itogo }}</td>
					</tr>
				{% endfor %}
			</table>
		</div> #}

		<div class="mini_header mt0"><span>БИЛЕТЫ <div class="badge">{{ person.tickets|length }}</div></span></div>

		<div class="newblo">
			<table class="table stacktable">
				<tr>
					<td>Номер</td>
					<td>Дата</td>
					<td>Статус</td>
					<td>Стоимость</td>
					<td>Кол-во</td>
					<td>Итог</td>
				</tr>
				{% for row in person.tickets|reverse %}
					<tr>
						<td><a href="/crm/tickets/view?id={{ row.id }}">{{ row.id }}</a></td>
						<td>{{ row.date|date('d.m.Y в H:i') }}</td>
						<td>{% if row.status == 5 %} №5 - оплачен 
							{% elseif row.status == 1 %} №1 - создан
							{% elseif row.status == 7 %} №7 - возвращен 
							{% elseif row.status == 0 %} №0 - бронь снята {% endif %}
						</td>
						<td>{{ row.money }}</td>
						<td>{{ row.count }}</td>
						<td>{{ row.summa }}</td>
					</tr>
				{% endfor %}
			</table>
		</div>

		<div class="mini_header mt0"><span>АБОНЕМЕНТЫ <div class="badge">{{ person.abonements|length }}</div></span></div>

		<div class="newblo">
			<table class="table stacktable">
				<tr>
					<td>Начало</td>
					<td>Окончание</td>
					<td>Остаток</td>
					<td>Итог</td>
				</tr>
				{% for row in person.abonements|reverse %}
					<tr>
						<td>{{ row.start|date('d.m.Y в H:i') }}</td>
						<td>{{ row.end|date('d.m в H:i') }}</td>
						<td>{{ row.balance }}</td>
						<td>{{ row.price }}</td>
					</tr>
				{% endfor %}
			</table>
		</div>

		<div class="mini_header mt0"><span>АРЕНДЫ <div class="badge">{{ person.rents|length }}</div></span></div>

		<div class="newblo">
			<table class="table stacktable">
				<tr>
					<td>Начало</td>
					<td>Окончание</td>
					<td>Итог</td>
				</tr>
				{% for row in person.rents|reverse %}
					<tr>
						<td>{{ row.start|date('d.m.Y в H:i') }}</td>
						<td>{{ row.end|date('d.m в H:i') }}</td>
						<td>{{ row.money }}</td>
					</tr>
				{% endfor %}
			</table>
		</div>

	</div>

</div>