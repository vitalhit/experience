<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<button type="button" class="left_toggle"><span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span></button>
			<h2>{{ event.biblioevents.name }} </h2>
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/event_step.twig', {'biblioevent' : event.biblioevents, 'user' : user}) | raw }}
	</div>

	<div class="col-xs-12 col-lg-9">
		<table class="tb hidden-xs">
			<tr>
				<th>#</th>
				<th>Дата</th>
				<th>Купил</th>
				<th colspan="3">Гость</th>
				<th>Билет</th>
				<th class="tar">Итог</th>
				<th></th>
			</tr>
			{% for tik in tickets %}
				<tr class="{% if tik.status == 5 or tik.summa == 0 %} green {% elseif tik.status == 8 %} black {% elseif tik.status == 7 %} red {% else %} yellow {% endif %}">
					<td><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}">{{ tik.id }}</a></td>
					<td>{{ tik.events.date|date('d.m H:i') }}</td>
					<td>{{ tik.date|date('d.m H:i') }}</td>
					<td><a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.second_name }}</a></td>
					<td>{{ tik.persons.name }}</td>
					<td>{{ tik.persons.middle_name }}</td>
					<td>{{ tik.seats.name }}</td>
					<td class="tar">{{ tik.summa }}</td>
					<td class="tar">{{ tik.barcode }}</td>
				</tr>
			{% endfor %}
		</table>

		<div class="tbmob visible-xs">
			{% for tik in tickets %}
				<div class="newblo{% if tik.status == 5 or tik.summa == 0 %} gtop {% elseif tik.status == 8 %} dtop {% elseif tik.status == 7 %} rtop {% else %} ytop {% endif %}">
					<div class="col-xs-4"><span class="mini"># {{ tik.id }}</span></div>
					<div class="col-xs-4"><span class="mini">Куп {{ tik.date|date('d.m') }}</span></div>
					<div class="col-xs-4"><span class="mini">Дата {{ tik.events.date|date('d.m') }}</span></div>
					<div class="clear"></div>

					<div class="col-xs-12"><span class="mini">{{ tik.persons.mail }} </span><br>
						<a target="_blank" href="/crm/persons/view?id={{ tik.persons.id }}">{{ tik.persons.name }} {{ tik.persons.second_name }}</a>
					</div>
					<div class="clear"></div>

					<div class="col-xs-12">{{ tik.seats.name }}</div>
					<div class="clear"></div>

					<div class="col-xs-4"><b>{{ tik.money }}</b>р</div>
					<div class="col-xs-4">* <b>{{ tik.count }}</b></div>
					<div class="col-xs-4">= <b>{{ tik.summa }}</b>р</div>
					<div class="clear"></div>

					<div class="col-xs-2 tac">{% if tik.send == 1 %}<span class="glyphicon glyphicon-envelope"></span>{% endif %}</div>
					<div class="col-xs-4 tac" tag="{{ tik.status_come }}">{% if tik.status_come == 1 %}Пришел{% elseif tik.status_come == 2 %}Нет{% endif %}</div>
					<div class="col-xs-3 tac"><a class="comeinmob" tag="{{ row.biblioevent.id }}" id="{{ tik.id }}"><span class="glyphicon glyphicon-ok-circle"></span></a></div>
					<div class="col-xs-3 tac"><a target="_blank" href="/crm/tickets/view?id={{ tik.id }}"><span class="glyphicon glyphicon-eye-open"></span></a></div>
				</div>
			{% endfor %}
		</div>
	</div>
</div>


