<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<h2>Редактировать даты: {{ biblioevent.name }}<sup><a href="/crm/events/update?id={{model.id}}"><span class="glyphicon glyphicon-pencil"></a></sup> | {{ biblioevent.cities.name }}</h2>
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/event_step.twig', {'biblioevent' : biblioevent, 'user' : user}) | raw }}
	</div>

	<div class="col-xs-12 col-lg-9">
		<table class="tb dates">
			<tbody>
				<tr>
					<th>Даты события</th>
					<th>Мест</th>
					<th class="tac">Билеты + рег.</th>
					<th></th>
					<th colspan="2"></th>
				</tr>
				{% for row in dates %}
					<tr class="{% if (row.date.status == 0) or (row.date.date|date('Y-m-d') < now|date('Y-m-d')) %} noactive black {% else %} green {% endif %}">
						<td>{{ row.date.date|date('d.m H:i') }}
							<small>{% if row.date.cancel == 1 %}<span class="glyphicon glyphicon-ban-circle text-danger"></span>{%else%}<span class="glyphicon glyphicon-ok text-success"></span>  {%endif%} {{row.date.id}}</small>
							</td>
						<td><a href="/crm/seats/create?event_id={{ row.date.id }}&biblioeventid={{ row.date.event_id }}">
								{% if row.s_count == 0 %} <span class="cred normal">нет!</span> {% else %} {{ row.s_count - row.t_zayavka_c - row.t_back_c - row.t_pay_c}} / {{ row.s_count }} {% endif %}
							</a></td>
						<td class="tac bl c_blue"> <a href="/crm/biblioevents/view?id={{ biblioevent.id }}&event_id={{ row.date.id }}">{{ row.t_pay_c_t }}</a> + {{ row.t_reg_c }} </td>
						
						<td class="tac bl c_green">{{ 0 + row.t_pay_s }}<span>р</span></td>
						<td class="bl mini">
							<a href="/{{row.date.places.cities.alias}}/place/{{row.date.places.alias}}">{{row.date.places.name}}</a> <br>
							
							{% if  row.bands is not empty %}
							Артисты: <br>
							{% for one in row.bands %}
							<a href="/band/{{ one.band.alias }}">{{ one.band.name }}</a><sup><a href="/crm/band/view?id={{ one.band.id }}">edit</a></sup></div>
							{% endfor %}
							{% else %}
							{% endif %}
							{% if row.date.info %}<br>{{ row.date.info }}{% endif %}
						</td>
						<td><a class="din" href="/crm/events/update?id={{ row.date.id }}"><span class="glyphicon glyphicon-pencil"></span></a><br>
						<a href="/crm/events/barcode?id={{ row.date.id }}"><span class="glyphicon glyphicon-barcode"></span></a>
						<br><a href="/crm/events/duplicate?id={{ row.date.id }}"><span class="glyphicon glyphicon-duplicate"></span></a>
						<br>
						<a href="/crm/biblioevents/viewcsvall?id={{ biblioevent.id }}&event_id={{ row.date.id }}">CSV</a>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		<div class="clear mt20"></div>
			
		{{ this.render('_form_event.php', {'model' : model, 'biblioevent' : biblioevent, 'biblioevents' : biblioevents}) | raw }}

		{% if model.id %}
			<div class="clear"></div>
			<h3 class="tal">Bands</h3>
			{% for row in mybands %}
				<div class="din btn btn-info">{{ row.band.name }}<a class="del_in_btn" href="/crm/events/banddel?id={{ model.id }}&band={{ row.band_id }}">X</a></div>
			{% endfor %}
			<div class="col-xs-12 col-lg-3">
				<select class="form-control din" name="Бенды" onchange="top.location.href=this.options[this.selectedIndex].value;">
					<option>Добавить бенд</option>
					{% for row in bands %}
						<option value="/crm/events/bandadd?id={{ model.id }}&band={{ row.id }}">{{ row.name }}</option>
					{% endfor %}
				</select>
			</div>
		{% endif %}
	</div>
</div>



<script type="text/javascript">
	// Даты
	$(document).ready(function() {
		$('#events-event_id').on('change', function() {
			var biblioeventid = this.value;
			$.ajax({
				type: 'get',
				url: "/crm/events/get-dates",
				data: {'biblioeventid': biblioeventid},
				response: 'text',
				success: function(data){
					$('.dates').html(data);
					$('.left_blo').css({minHeight: $('.wrap').height()});
				}
			}); 
		});
	});
</script>