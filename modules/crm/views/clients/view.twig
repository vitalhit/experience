    <div class="row">
    <div class="col-xs-12 col-lg-3 left_blo">
        <div class="stiky">
            <div class="newblo">
                {% if client.image %}
                    <img src="/uploads/users/{{ client.image }}" class="img-responsive img-circle">
                {% else %}
                    <img src="/images/noimage.png" class="img-responsive img-circle">
                {% endif %}
                <h2 class="mt0">{% if client.name %}{{ client.name }} {{ client.second_name }}{% endif %}</h2>
                <a href="/crm/clients/update?id={{ client.id }}" class="btn btn-primary ma w120">Редактировать</a>
                <h4>User_id: {{ user_id }}<br>Профиль id: {{ client.id }}</h4>
                <p><b>Статус:</b> {{ client.status }}</p>
                <p><b>Дата рождения:</b> {{ client.birthday|date('d.m.Y') }}</p>
                <p><b>E-mail:</b> {{ client.mail }}</p>
                <p><b>Телефон:</b> {{ client.phone }}</p>
                <p><b>Пол:</b> {% if client.sex == 0 %} женщина {% else %} мужчина {% endif %} </p>
                <p><b>Группы:</b> {{ client.groups }}</p>
                <p><b>Откуда:</b> {{ client.froms.url }}</p>
                <p><b>Получать письма:</b> {% if client.sendmail == 1 %} Да {% else %} Нет {% endif %} </p>
                <p><b>Пожелания:</b> {{ client.vishes }}</p>
            </div>
            
        </div>
    </div>
    <div class="col-xs-12 col-lg-9">
        <div class="newblo">
            <div class="row">
                <div class="col-xs-3"><a class="btn  btn-primary" href="/crm/clients/">клиенты</a> <a class="btn  btn-primary" href="/crm/clients/create">+</a> <h3 class="itog"></h3></div>

                <div class="col-xs-3"><h3 class="itog"></h3></div>
                <div class="col-xs-3"><h3 class="itog"></h3></div>
                <div class="col-xs-3"><h3 class="itog"></h3></div>

            </div>
        </div>
        {% if client.info %}
        <div class="newblo"><p>{{ client.info }}</p></div>
        {% endif %}
        {% if client.tags %}
        <div class="newblo"><p>{{ client.tags }}</p></div>
        {% endif %}
