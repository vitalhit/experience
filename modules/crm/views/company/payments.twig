<div class="row">
	<div class="col-xs-12 col-lg-12">
		<div class="newblo">
			<h2>Доходы <br><span class="tac">Продажи билетов, без комиссии</span></h2>
		</div>
	</div>
	<div class="col-xs-12 col-lg-3 left_blo">
		{{ this.render('/module/company_step.twig', {'company' : company}) | raw }}
	</div>


	
	<div class="col-xs-12 col-lg-4 ">
	<div class="steps">
		<div class="newblo">
			<h2>История выплат</h2>
			<table class="tb">
				{% set paysum = 0 %}
				{% for item in payments %}
					<tr>
						<td>{{ item.create_at|date('d.m.Y') }}<br><small></small> </td>
						<td class="tar"><a title="{{ item.info }}">{{ item.summa|number_format(0, '.', ' ') }}</a></td>
						<td>
							{% if item.status == 1 %}
								<span class="glyphicon glyphicon-hourglass c_yell"></span>
							{% elseif item.status == 2 %}
								<span class="glyphicon glyphicon-ok c_green"></span>
							{% elseif item.status == 3 %}
								<span class="glyphicon glyphicon-ok c_green"><span class="glyphicon glyphicon-ok c_green"></span></span>
								{% set paysum = paysum + item.summa %}
							{% else %}
								-
							{% endif %}
						</td>
						<td><a href="https://igoevent.com/crm/events/finance?id={{ item.event_id }}">{{ item.event_id }}</a></td>						
					</tr>
				{% endfor %}
				<tr>
					<td><b>Итог</b></td>
					<td></td>
					<td class="tar"><b>{% if paysum %}{{ paysum }} р{% endif %}</b></td>
				</tr>
			</table>
		</div>
	</div>
	</div>
	<div class="col-xs-12 col-lg-4 ">
	<div class="steps">
		
		<div class="newblo">
			<h2>Вывести средства</h2>
			<p class="mini">До 10 000 рублей выводим раз в месяц, <br>от 10 000 — без ограничений.</p>
			<form id="vuvod" action="/crm/company/vuvod" method="POST">
				<input type="text" class="form-control mb10" name="summa" placeholder="Сумма вывода руб.">
				<input type="text" class="form-control mb10" name="info" placeholder="Ваша пометка">
				<input type="text" class="form-control mb10" name="event_id" placeholder="Event id">
				<button type="submit" class="btn btn-info pull-right">Вывести</button>
			</form>
		</div>
	</div>
	</div>
</div>
