{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
              
                <div class="col-xs-12 col-lg-12">
                    <h2>All invitings</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xs-12 col-lg-12">
        
        <a class="btn btn-success btn-sm" href="/crm/inviting/create"> добавить inviting <span class="glyphicon glyphicon-plus small"></span></a>
        <br><br>
        <table class="tb stacktable">
            <tr>

                <td>id</td>
                <td>event_id</td>
                <td>event_vk_id</td>
                <td>public_id</td>
                <td>public_vk_id</td>
                <td>info</td>
                <td>invite/all</td>
                <td>ignore&ban</td>
                <td>copy</td>
            </tr>
            {% for one in all %}
            <tr>
                <td><a href="/crm/inviting/update?id={{ one.id}}">{{ one.id}}</a></td>
                <td>{{ one.event_id}}</td>
                <td>{% if one.event_vk_id%}<a href="https://vk.com/public{{ one.event_vk_id}}">{{ one.event_vk_id}}</a>{%else%} - {% endif%}</td>
                <td>{{ one.public_id}}</td>
                <td>{% if one.public_vk_id%}<a href="https://vk.com/public{{ one.public_vk_id}}">{{ one.public_vk_id}}</a>{%else%} - {% endif%}</td>
                <td>{{ one.info}}</td>
                <td>{% if one.result_invite or one.result_all %} {{one.result_invite}} / {{one.result_all}} {% endif%} </td>
                <td>{% if one.result_ignore or one.result_ban %}{{one.result_ignore}} | {{one.result_ban}} {%endif%} </td>
                <td><a class="btn btn-sm btn-success"href="/crm/inviting/create?public_vk_id={{one.public_vk_id}}&event_vk_id={{one.event_vk_id}}&public_id={{ one.public_id}}&event_id={{ one.event_id}}&info={{ one.info}}">+</a></td>
            </tr>
            {% endfor %}
        </table>
    </div>
</div>

    {{link_pager_widget({
        'pagination': pages
    }) }}



    <div class="popup end popup_d"></div>

    <div class="overlay"></div>

