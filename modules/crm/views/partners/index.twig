{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
                <div class="col-xs-12 col-lg-3">
                    <form class="form-inline form_lite">
                        <input type="text" class="form-control who" name="referal" placeholder="Фамилия партнера" autocomplete="off">
                    </form>
                </div>
                <div class="col-xs-12 col-lg-9">
                    <h2>Все партнеры</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xs-12 col-lg-3 left_blo">
        {{ this.render('/module/person_step.twig', {'company' : company}) | raw }}
    </div>

    <div class="col-xs-12 col-lg-9">

        <table class="tb stacktable">
            <tr>
                <td></td>
               <!--<td></td>-->
                <td>Город</td><td>Title</td>
                
                <td>Телефон</td>
                <td>Инфо</td>
                <td>Группа</td>
                <!--<td>Статус</td>-->
                <td>vk.com</td>
            </tr>
            {% for partner in partners %}
            <tr>
                <td><span>{{ partner.id }}</span></td>
                <!--<td class="tac">
                    {% if partner.image %}
                    <img src="/uploads/users/{{ partner.image }}" class="w26 img-circle">
                    {% else %}
                    <img src="/web/images/noimage.png" class="w26 img-circle">
                    {% endif %}
                </td>-->
                <td><span>{{ partner.city }}</span></td>
                <td><a href="/crm/partners/update?id={{ partner.id }}">{{ partner.title }}</a><br><small><a href="/crm/partners/update?id={{ partner.id }}">{{ partner.second_name }} {{ partner.name }} {{ partner.middle_name }}</a></small></td>
                <td><small>
                    {% if partner.mail %}<a href="{{ partner.mail }}">{{ partner.mail }}</a><br>{% endif %}
                    
                    {% if partner.phone %}<a href="https://wa.me/{{ partner.phone }}?text=Здравствуйте, {{ partner.name }} {{ partner.middle_name }}. Пишу вам по поводу концерта. http://igoevent.com/msk?utm_source=whatsapp&amp;utm_medium=igoevent&amp;utm_campaign=massage">wap</a>{% endif %}

                </td>

                
                <td><span>{{ partner.info }}</span><br>
                    {% if partner.link_vk %}
                    <small><a class="btn btn-primary btn-xs" href="https://vk.com/{{ partner.link_vk }}">vk</a></small>
                    {% endif %}
                    {% if partner.link_fb %}
                    <small><a class="btn btn-primary btn-xs" href="{{ partner.link_fb }}">fb</a></small>
                    {% endif %}
                    {% if partner.link_yt %}
                    <small><a class="btn btn-primary btn-xs" href="{{ partner.link_yt }}">yt</a></small>
                    {% endif %}
                    {% if partner.link_insta %}
                    <small><a class="btn btn-primary btn-xs" href="https://instagram.com/{{ partner.link_insta }}/">insta</a></small>
                    {% endif %}
                    {% if partner.link_tt %}
                    <small><a class="btn btn-primary btn-xs" href="https://vk.com/{{ partner.link_tt }}">tt</a></small>
                    {% endif %}
                    {% if partner.link_tg %}
                    <small><a class="btn btn-primary btn-xs" href="https://vk.com/{{ partner.link_tg }}">tg</a></small>
                    {% endif %}
                </td>
                <td>{{ partner.groups|slice(0, 10) }}</td>
                <!--<td>{{ partner.status }}</td>-->
                <td><span><a href='https://vk.com/im?sel={{ partner.vk_id }}'>{{ partner.vk_id }}</a></span></td>
            </tr>
            {% endfor %}
        </table>
    </div>
</div>

    {{link_pager_widget({
        'pagination': pages
    }) }}



    <div class="popup end popup_d"></div>

    <div class="overlay"></div>



<script type="text/javascript">

    $(function(){

    //Живой поиск
    $('.who').bind("change keyup input click", function() {
        if(this.value.length >= 4){
            $.ajax({
                type: 'get',
                    url: "/crm/persons/personsfind", //Путь к обработчику
                    data: {'name':this.value},
                    response: 'text',
                    success: function(data){
                        $(".search_result").html(data).fadeIn(); //Выводим полученые данные в списке
                    }
                })
            $(".overlay").fadeIn();
            $(".form_lite").css({'zIndex': 9000});

        }
    })

    $(".search_result").hover(function(){
        $(".who").blur(); //Убираем фокус с input
    })

    //При выборе результата поиска, прячем список и заносим выбранный результат в input
    $(".search_result").on("click", "li", function(){
        s_user = $(this).text();
        //$(".who").val(s_user).attr('disabled', 'disabled'); //деактивируем input, если нужно
        $(".search_result, .overlay").fadeperson();
        $(".form_lite").css({'zIndex': 1000});
    })

})
</script>