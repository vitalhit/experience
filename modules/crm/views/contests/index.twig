{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
              
                <div class="col-xs-12 col-lg-12">
                    <h2>Все конкурсы</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xs-12 col-lg-3 left_blo">
        
    </div>

    <div class="col-xs-12 col-lg-9">
        
        <a class="btn btn-success btn-sm" href="/crm/contests/create"> добавить розыгрыш <span class="glyphicon glyphicon-plus small"></span></a>
        <br><br>
        <table class="tb stacktable">
            <tr>
                <td>id</td>
                <td>дата/изменить</td>
                <td>event_id</td>
                <td>+ ticket</td>
            
                <td> <span class="glyphicon glyphicon-pencil">status</span></td>
                <td>link</td>
                <td>выполнить</td> 
            </tr>
            {% for contest in contests %}
            {% if contest.status == 0 %}<tr>
                <td><span>{{ contest.id }}</span></td>
                <td>{% if status == 0 %}
                    <span class="{% if contest.status == 1 %}text-success{% elseif contest.status == 0 and contest.date_end|date('Y-m-d') <= now|date('Y-m-d') %} bg-danger {% else  %} bg-warning{% endif %}">{{ contest.date_end|date('Y-m-d') }}
                    </span>
                    {% endif %}
                </td>
                <td><span class=""><a href="/crm/events/update?id={{ contest.event_id }}">{{ contest.event_id }}</a></span></td><td><span><a href="/crm/seats/create?event_id={{ contest.event_id }}">добавить билет</a></span></td>
                <td><span><a href="/crm/contests/update?id={{ contest.id }}">Итоги не подведены({{ contest.status }})</a></span></td>
                <td><span><a href="{{ contest.link }}">{{ contest.link }}</a></span></td>
                </td>
                <td>{% if contest.status == 0 %}<span class="text-danger glyphicon glyphicon-check"></span>{% elseif contest.status == 1  %}<span class="text-success glyphicon glyphicon-check"></span>{% endif  %}</td>
            </tr>
            {% endif %}
            {% endfor %}

            {% for contest in contests %}
            {% if contest.status == 1 %}<tr>
                <td><span>{{ contest.id }}</span></td>
                <td>{% if status == 0 %}
                    <span class="{% if contest.status == 1  %}text-success{% else %} text-danger{% endif %}">{{ contest.date_end|date('Y-m-d') }}
                    </span>
                    {% endif %}
                </td>
                <td><span class=""><a href="/crm/events/update?id={{ contest.event_id }}">{{ contest.event_id }}</a></span></td><td><span><a href="/crm/seats/create?event_id={{ contest.event_id }}">добавить билет</a></span></td>
            
                <td><span><a href="/crm/contests/update?id={{ contest.id }}">Итоги подведены({{ contest.status }})</a></span></td>
                <td><span><a href="{{ contest.link }}">{{ contest.link }}</a></span></td>
                </td>
                <td>{% if contest.status == 0 %}<span class="text-danger glyphicon glyphicon-check"></span>{% elseif contest.status == 1  %}<span class="text-success glyphicon glyphicon-check"></span>{% endif  %}</td>
            </tr>
            {% endif %}
            {% endfor %}
        </table>
    </div>
</div>

    {{link_pager_widget({
        'pagination': pages
    }) }}



    <div class="popup end popup_d"></div>

    <div class="overlay"></div>



<script type="text/javascript">

    $(function(){

    //Живой поиск
    $('.who').bind("change keyup input click", function() {
        if(this.value.length >= 4){
            $.ajax({
                type: 'get',
                    url: "/crm/persons/personsfind", //Путь к обработчику
                    data: {'name':this.value},
                    response: 'text',
                    success: function(data){
                        $(".search_result").html(data).fadeIn(); //Выводим полученые данные в списке
                    }
                })
            $(".overlay").fadeIn();
            $(".form_lite").css({'zIndex': 9000});

        }
    })

    $(".search_result").hover(function(){
        $(".who").blur(); //Убираем фокус с input
    })

    //При выборе результата поиска, прячем список и заносим выбранный результат в input
    $(".search_result").on("click", "li", function(){
        s_user = $(this).text();
        //$(".who").val(s_user).attr('disabled', 'disabled'); //деактивируем input, если нужно
        $(".search_result, .overlay").fadeperson();
        $(".form_lite").css({'zIndex': 1000});
    })

})
</script>