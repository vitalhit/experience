{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
              
                <div class="col-xs-12 col-lg-12">
                    <h2>Все задачки</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xs-12 col-lg-12">
        
        <a class="btn btn-success btn-sm" href="/crm/todos/create"> добавить задачку <span class="glyphicon glyphicon-plus small"></span></a>
        <br><br>
        <table class="tb stacktable">
            <tr>
                <td>id</td>

                <td>title</td>
                <td>link</td>
                <td>info</td>
                <td>status</td>
                <td>done</td>
                <td>today</td>
                <td>to do</td>
                
            </tr>
            {% for todo in todos %}
            <tr>
                <td>{{todo.id}}</td>
                <td><a href="/crm/todos/update?id={{todo.id}}">{{todo.title}}</a></td>

                <td><a href="{{todo.link}}">{{todo.link}}</a></td>
                <td>{{todo.info}}</td>
                <td>{{todo.status}}</td>
                
                <td>   
                    {% for row in steps %}

                        {% if row.todo_id == todo.id %} 
                        <span class="btn btn-success btn-sm">{{ row.date_create|date('Y-m-d') }} ({{row.user_id}})</span>

                        {% endif %}
                    {% endfor %}
                </td>
                <td>   
                    {% for row in steps %}

                        {% if row.todo_id == todo.id and row.date_create|date('Y-m-d') == now|date('Y-m-d')%} 
                       <span class="btn btn-success btn-sm">{{ row.date_create|date('Y-m-d') }} ({{row.user_id}})</span>

                        {% endif %}
                    {% endfor %}
                </td>
                <td><a href="/crm/todos/add?id={{todo.id}}">add</a></td>
            </tr>
            {% endfor %}
        </table>
    </div>
</div>

    {{link_pager_widget({
        'pagination': pages
    }) }}



    <div class="popup end popup_d"></div>

    <div class="overlay"></div>



<script type="text/javascript">

    $(function(){

    //Живой поиск
    $('.who').bind("change keyup input click", function() {
        if(this.value.length >= 4){
            $.ajax({
                type: 'get',
                    url: "/crm/persons/personsfind", //Путь к обработчику
                    data: {'name':this.value},
                    response: 'text',
                    success: function(data){
                        $(".search_result").html(data).fadeIn(); //Выводим полученые данные в списке
                    }
                })
            $(".overlay").fadeIn();
            $(".form_lite").css({'zIndex': 9000});

        }
    })

    $(".search_result").hover(function(){
        $(".who").blur(); //Убираем фокус с input
    })

    //При выборе результата поиска, прячем список и заносим выбранный результат в input
    $(".search_result").on("click", "li", function(){
        s_user = $(this).text();
        //$(".who").val(s_user).attr('disabled', 'disabled'); //деактивируем input, если нужно
        $(".search_result, .overlay").fadeperson();
        $(".form_lite").css({'zIndex': 1000});
    })

})
</script>