{{ use('/yii/widgets') }}

<ul class="search_result"></ul>

<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <div class="row">
              
                <div class="col-xs-12 col-lg-12">
                    <h2>Все шаги</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xs-12 col-lg-12">
        
        <a class="btn btn-success btn-sm" href="/crm/stepstep/create"> добавить шаг задачи <span class="glyphicon glyphicon-plus small"></span></a>
        <br><br>
        <table class="tb stacktable">
            <tr>
                <td>id</td>
                <td>title</td>
                <td>link</td>
                <td>info</td>
                <td>status</td>
                <td>minutes</td>
                <td>today</td>
                <td>to do</td>
            </tr>
            {% for step in todosteps %}
            
            <tr>
                <td>{{step.id}}</td>
                <td><a href="/crm/todostep/update?id={{step.id}}">{%if step.title%}{{step.title}}{%else%}..{% endif%}</a></td>

                <td>{{step.user_id}}</td>
                <td>{{step.info}}</td>
                <td>{{step.status}}</td>
                <td>{{step.minutes}}</td>
                <td><small>{{step.date_create}}<br>{{step.date_done}}
                </small></td>
                <td><a href="/crm/steps/add?id={{todo.id}}">add</a></td>
            </tr>
            
            {% endfor %}
            <tr>
                <td>id</td>
                <td>title</td>
                <td>link</td>
                <td>info</td>
                <td>status</td>
                <td>done</td>
                <td>today</td>
                <td>to do</td>
            </tr>
            
        </table>
    </div>
</div>

    {{link_pager_widget({
