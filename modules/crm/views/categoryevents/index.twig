<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <h2>Категории событий</h2>
        </div>
    </div>
    <div class="col-xs-12 col-lg-3 left_blo">
        {{ this.render('/module/event_step.twig') | raw }}
    </div>

    <div class="col-xs-12 col-lg-9">


        <table class="tb stacktable">
            <tr>
                <th>id</th>
                <th>Категория</th>
                <th colspan="2">Редактировать</th>
            </tr>
            {% for row in categoryevents %}
                <tr>
                    <td>{{ row.id }}</td>
                    <td>{{ row.category }}</td>
                    <td><a href="/crm/categoryevents/update?id={{ row.id }}"><span class="glyphicon glyphicon-pencil"></span></a></td>
                    <td><a href="/crm/categoryevents/delete?id={{ row.id }}" title="Delete" aria-label="Delete" data-confirm="Уверены в том, что хотите удалить?" data-method="post"><span class="glyphicon glyphicon-trash"></span></a>
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
</div>