			</p>
		</div>
	</div> -->

	<div class="line"></div>

	<div class="mt50"></div>

	<div class="row">
		<div class="col-xs-12 col-sm-4 col-sm-offset-4">
			<input type="submit" name="type" class="btn btn-warning" value="Завершить">
		</div>  
	</div>

</form>
