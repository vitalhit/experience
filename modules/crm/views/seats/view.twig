<div class="row">
    <div class="col-xs-12 col-lg-12">
        <div class="newblo">
            <h2>{{ biblioevent.name}}</h2>
        </div>
    </div>
    <div class="col-xs-12 col-lg-3">
        {{ this.render('/module/event_step.twig', {'biblioevent' : biblioevent}) | raw }}
    </div>

    <div class="col-xs-12 col-lg-9">
        <table class="tb seats">
            <tbody>
                <tr>
                    <th>Название</th>
                    <th class="tar">Цена</th>
                    <th class="tar">Кол-во</th>
                    <th class="tar">Доступно</th>
                    <th>Код</th>
                    <th class="tar">Лимит</th>
                    <th>Статус</th>
                    <th>Можно</th>
                    <th>Инфо</th>
                    <th></th>
                    <th></th>
                </tr>
                {% for row in seats %}
                    <tr>
                        <td>{{ row.seat.name }}</td>
                        <td class="tar">{{ row.seat.price }} р</td>
                        <td class="tar">{{ row.seat.count }}</td>
                        <td class="tar">{{ row.instock }}</td>
                        <td>{{ row.seat.promocode  }}</td>
                        <td class="tar">{{ row.seat.promolimit  }}</td>
                        <td>{{ row.seat.status }}</td>
                        <td>{% if row.seat.afterpay == 1 %}Да{% else %}Нет{% endif %}</td>
                        <td>{{ row.seat.info }}</td>
                        <td><a href="/crm/seats/update?id={{ row.seat.id }}&biblioeventid={{ biblioevent.id }}"><span class="glyphicon glyphicon-pencil"></span></a></td>
                        <td><a href="/crm/seats/delete?id={{ row.seat.id }}&biblioeventid={{ biblioevent.id }}" data-confirm="Уверены, что хотите удалить?" data-method="post"><span class="glyphicon glyphicon-trash"></span></a></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="col-xs-12 col-lg-9">
        {{ this.render('_form.php', {'model' : model, 'dates' : dates, 'seats' : seats}) | raw }}


        <!-- <div class="col-xs-12 col-lg-4 r_info">
            <p>Название билета будет видеть гость, пишите кратко и понятно, например: Кресла 1 ряд, или балкон. Создайте столько типов билетов для вашей рассадки, сколько у вас ценовых категорий.</p>
            <p>То есть вам нужно создать этот тип билета, нажать "создать" и вновь вернуться к этой странице.</p>
        </div> -->

        <div class="col-xs-12">
            {% for rows in s_sort %}
                <div class="row">
                    {% for key, row in rows %}
                        {% for c in color %}
                            {% if c.p == row %}
                                <div class="seat sc{{ loop.index }} {% if row < 0 %}sc_none{% endif %}" tag="{{ key }}">{{ row }}</div>
                            {% endif %}          
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

    </div>
</div>



<script type="text/javascript">
$(document).ready(function() {
    $('#seats-event_id').on('change', function() {
        var event_id = this.value;
        $.ajax({
            type: 'get',
            url: "/crm/seats/get-seats",
            data: {'event_id': event_id},
            response: 'text',
            success: function(data){
                $('.seats').html(data);
            }
        }); 
    });
});

$('.steps .type').addClass('active');
</script>