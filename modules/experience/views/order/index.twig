<div class="experience-orders container" style="max-width: 960px; margin: 2rem auto; padding: 0 1rem;">
	<h1>Список заказов</h1>

	<table class="table table-bordered table-striped" style="margin-top: 1rem;">
		<thead>
			<tr>
				<th>Заказ</th>
				<th>Событие</th>
				<th>Дата</th>
				<th>Сумма</th>
				<th>Статус</th>
			</tr>
		</thead>
		<tbody>
			{% for order in orders %}
				<tr>
					<td>
						<a href="/experience/order/{{ order.order_id }}">{{ order.order_id }}</a>
					</td>
					<td>{{ order.biblioevent ? order.biblioevent.name : '—' }}</td>
					<td>{{ order.date ? order.date|date('d.m.Y H:i') : '—' }}</td>
					<td>{{ order.sum|number_format(0, '', ' ') }} ₽</td>
					<td>{{ order.statusLabel }}</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5" style="text-align: center;">Заказов пока нет.</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
</div>
