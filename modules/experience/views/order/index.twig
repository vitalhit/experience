<div class="experience-orders container" style="max-width: 960px; margin: 2rem auto; padding: 0 1rem;">
	<h1>Список заказов</h1>

	<h2 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">Предстоящие</h2>
	<table class="table table-bordered table-striped" style="margin-top: 0;">
		<thead>
			<tr>
				<th>Заказ</th>
				<th>Событие</th>
				<th>Дата</th>
				<th>Сумма</th>
				<th>Статус</th>
			</tr>
		</thead>
		<tbody>
			{% for order in ordersFuture %}
				<tr>
					<td>
						<a href="/experience/order/{{ order.order_id }}">{{ order.order_id }}</a>
					</td>
					<td>{{ order.biblioevent ? order.biblioevent.name : '—' }}</td>
					<td>{{ order.eventDateFormatted ?: (order.date ? order.date|date('d.m.Y H:i') : '—') }}</td>
					<td>{{ order.sum|number_format(0, '', ' ') }} ₽</td>
					<td>{{ order.statusLabel }}</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5" style="text-align: center;">Нет предстоящих заказов.</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<h2 style="margin-top: 2rem; margin-bottom: 0.5rem;">Прошедшие</h2>
	<table class="table table-bordered table-striped" style="margin-top: 0;">
		<thead>
			<tr>
				<th>Заказ</th>
				<th>Событие</th>
				<th>Дата</th>
				<th>Сумма</th>
				<th>Статус</th>
			</tr>
		</thead>
		<tbody>
			{% for order in ordersPast %}
				<tr>
					<td>
						<a href="/experience/order/{{ order.order_id }}">{{ order.order_id }}</a>
					</td>
					<td>{{ order.biblioevent ? order.biblioevent.name : '—' }}</td>
					<td>{{ order.eventDateFormatted ?: (order.date ? order.date|date('d.m.Y H:i') : '—') }}</td>
					<td>{{ order.sum|number_format(0, '', ' ') }} ₽</td>
					<td>{{ order.statusLabel }}</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5" style="text-align: center;">Нет прошедших заказов.</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
</div>
