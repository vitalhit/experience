<div class="experience-order container" style="max-width: 720px; margin: 2rem auto; padding: 0 1rem;">
	<header style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eee; background: none; background-image: none;">
		<nav aria-label="Хлебные крошки" style="margin-left: 20px;">
			<a href="/experience/order">Все заказы</a>
			<span style="margin: 0 0.35em; color: #999;">→</span>
			<span>{{ order_id }}</span>
		</nav>
		<a href="/site/logout" class="btn btn-default" style="padding: 6px 12px; text-decoration: none;">Выход</a>
	</header>

	<h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">{{ biblioevent.name }}</h1>
	{% if biblioevent.subtitle %}
		<p style="color: #666; margin-bottom: 1.5rem;">{{ biblioevent.subtitle }}</p>
	{% endif %}

	<div style="margin-bottom: 1.5rem;">
		<strong>Экскурсовод</strong>: 
		{{ guideName }}
	</div>

	<dl style="display: grid; gap: 0.5rem 1rem; grid-template-columns: auto 1fr;">
		<dt>Дата</dt>
		<dd>{{ dateFormatted ?: '—' }}</dd>

		<dt>Начало</dt>
		<dd>{{ timeFormatted ? (timeFormatted ~ ' местное время') : '—' }}</dd>

		<dt>Участников</dt>
		<dd>{{ participantsCount }}</dd>

		<dt>Стоимость</dt>
		<dd>{{ sum|number_format(0, '', ' ') }} ₽</dd>
	</dl>

	<p style="margin: 1rem 0; padding: 0.75rem; background: #f5f5f5; border-radius: 4px;">
		<strong>{{ statusLabel }}</strong>
	</p>

	{% if canPay %}
		<p style="margin: 1rem 0;">
			Внесите предоплату до завершения регистрации. После оплаты вам станут доступны контакты организатора и место встречи.
		</p>
		{% if meetingPlace %}
			<p style="margin: 0.5rem 0;"><strong>Примерное место встречи:</strong> {{ meetingPlace }}</p>
		{% endif %}
	{% endif %}

	<div style="margin: 1.5rem 0; padding: 1rem; border: 1px solid #eee; border-radius: 4px;">
		<p><strong>Дата начала</strong><br>{{ datetimeFormatted ?: '—' }}</p>
		<p><strong>Количество участников</strong><br>{{ participantsCount }} человек</p>
		<p><strong>К оплате</strong><br>{{ sum|number_format(0, '', ' ') }} ₽</p>
	</div>

	{% if canPay %}
		
		<p style="margin: 1rem 0;">
			<a href="{{ paymentUrl }}" class="btn btn-primary" style="display: inline-block; padding: 12px 24px;">Оплатить картой {{ sum|number_format(0, '', ' ') }} ₽</a>
		</p>
	{% endif %}

	<section class="experience-comments" style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid #eee;">
		<h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Комментарии</h2>
		{% if comments is defined and comments|length > 0 %}
			<ul style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
				{% for c in comments %}
					<li style="margin-bottom: 1rem; padding: 0.75rem; background: #f9f9f9; border-radius: 4px;">
						<div style="font-size: 0.85rem; color: #666; margin-bottom: 0.25rem;">
							{% if c.author_type == 1 %}Гость{% elseif c.author_type == 2 %}Гид{% elseif c.author_type == 3 %}Менеджер{% else %}Автор{% endif %}
							{% if c.author %}{{ c.author.name }} {{ c.author.second_name }}{% endif %}
							— {{ c.created_at|date('d.m.Y H:i') }}
						</div>
						<div style="white-space: pre-wrap;">{{ c.body }}</div>
					</li>
				{% endfor %}
			</ul>
		{% else %}
			<p style="color: #888; margin-bottom: 1rem;">Пока нет комментариев.</p>
		{% endif %}
		<form method="post" action="{{ addCommentUrl }}" style="max-width: 100%;">
			<input type="hidden" name="{{ csrfParam }}" value="{{ csrfToken }}">
			<label for="comment-body" style="display: block; margin-bottom: 0.5rem;">Добавить комментарий</label>
			<textarea id="comment-body" name="body" rows="3" maxlength="1000" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; color: black!important; background: #fff;" placeholder="Текст сообщения (до 1000 символов)"></textarea>
			<button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;">Отправить</button>
		</form>
	</section>
</div>
